{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/m6/direct-certification-report/v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id","schema_version","suite_id","mode","source_revision","result","certification_status","freeze_before_sha256","freeze_after_sha256","freeze_stable","prerequisite_evidence","direct_route","assertion_count","assertion_pass_count","negative_count","negative_pass_count","certified_scope","excluded_scope","boundaries","underlying_evidence","errors"],
  "properties": {
    "schema_id":{"const":"taoge://schemas/m6/direct-certification-report/v0.1"},
    "schema_version":{"const":"0.1"},
    "suite_id":{"const":"M6-DIRECT-CERTIFICATION-0.1"},
    "mode":{"enum":["compile_smoke","certification"]},
    "source_revision":{"type":"string","minLength":1},
    "result":{"enum":["pass","fail"]},
    "certification_status":{"enum":["not_run_compile_smoke_only","certified","failed"]},
    "freeze_before_sha256":{"type":"string","pattern":"^sha256:[a-f0-9]{64}$"},
    "freeze_after_sha256":{"type":"string","pattern":"^sha256:[a-f0-9]{64}$"},
    "freeze_stable":{"type":"boolean"},
    "prerequisite_evidence":{
      "type":"object",
      "additionalProperties":false,
      "required":["status","evaluator_report","runtime_report","source_revision","freeze_sha256"],
      "properties":{
        "status":{"enum":["not_checked_compile_smoke_only","certified_same_digest","failed"]},
        "evaluator_report":{"type":"string"},
        "runtime_report":{"type":"string"},
        "source_revision":{"type":"string"},
        "freeze_sha256":{"type":"string"}
      }
    },
    "direct_route":{
      "type":"object",
      "additionalProperties":false,
      "required":["route_id","runtime_generation","session_binding_status","component_count","artifact_count","event_count","wait_status","resume_status","rebuild_status","replay_status","unexpected_writer_count"],
      "properties":{
        "route_id":{"const":"direct"},
        "runtime_generation":{"const":"kernel_v1_current"},
        "session_binding_status":{"enum":["created_and_verified","failed"]},
        "component_count":{"type":"integer","minimum":0},
        "artifact_count":{"type":"integer","minimum":0},
        "event_count":{"type":"integer","minimum":0},
        "wait_status":{"enum":["waiting_human","failed"]},
        "resume_status":{"enum":["completed","failed"]},
        "rebuild_status":{"enum":["pass_byte_stable","failed"]},
        "replay_status":{"enum":["reused_no_new_event","failed"]},
        "unexpected_writer_count":{"type":"integer","minimum":0}
      }
    },
    "assertion_count":{"type":"integer","minimum":1},
    "assertion_pass_count":{"type":"integer","minimum":0},
    "negative_count":{"const":6},
    "negative_pass_count":{"type":"integer","minimum":0,"maximum":6},
    "certified_scope":{"type":"array","minItems":1,"items":{"type":"string"}},
    "excluded_scope":{"type":"array","minItems":1,"items":{"type":"string"}},
    "boundaries":{
      "type":"object",
      "additionalProperties":false,
      "required":["network_called","provider_called","private_account_used","real_human_decision_used","semantic_quality_certified","manual_patch_used"],
      "properties":{
        "network_called":{"const":false},
        "provider_called":{"const":false},
        "private_account_used":{"const":false},
        "real_human_decision_used":{"const":false},
        "semantic_quality_certified":{"const":false},
        "manual_patch_used":{"const":false}
      }
    },
    "underlying_evidence":{"type":"object"},
    "errors":{"type":"array","items":{"type":"string"}}
  }
}
