{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/r7/image-asset-set/v0.3",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "image_asset_set_id", "coverage_ledger_ref", "test_profile", "finalize_requested_at", "assets", "delivery_bindings", "provider_task_count", "provider_attempt_count", "provider_invocation_count", "source_capture_attempt_count", "postprocess_count", "asset_set_status", "next_skill"],
  "properties": {
    "schema_id": {"const": "taoge://schemas/r7/image-asset-set/v0.3"},
    "schema_version": {"const": "0.3"},
    "image_asset_set_id": {"type": "string", "minLength": 1},
    "coverage_ledger_ref": {"type": "object"},
    "test_profile": {"enum": ["production", "no_provider", "reuse_only"]},
    "finalize_requested_at": {"type": "string", "format": "date-time"},
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["asset_id", "asset_revision", "visual_task_id", "asset_role", "source_class", "route_decision", "parent_asset_ref", "relative_path", "sha256", "media_type", "role", "width_px", "height_px", "alt_text", "visual_text_summary", "provider_or_capture", "postprocess", "postprocess_record_path", "postprocess_record_sha256", "reuse_authorization_ref", "image2_runtime_profile", "evidence_parity_result", "sidecar_path", "sidecar_sha256", "generation_record_path", "generation_record_sha256", "visual_review_ref", "asset_status"],
        "properties": {
          "asset_id": {"type": "string", "minLength": 1},
          "asset_revision": {"type": "integer", "minimum": 1},
          "visual_task_id": {"type": "string", "minLength": 1},
          "asset_role": {"enum": ["base", "derived_rendition"]},
          "source_class": {"enum": ["source_bound_evidence", "explicit_existing_asset", "generated_context"]},
          "route_decision": {"type": "string"},
          "parent_asset_ref": {"type": ["object", "null"]},
          "relative_path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
          "media_type": {"type": "string"},
          "role": {"type": "string"},
          "width_px": {"type": "integer", "minimum": 1},
          "height_px": {"type": "integer", "minimum": 1},
          "alt_text": {"type": "string"},
          "visual_text_summary": {"type": "string"},
          "provider_or_capture": {"enum": ["image2", "source_capture", "authorized_existing_asset"]},
          "postprocess": {"type": "object"},
          "postprocess_record_path": {"type": ["string", "null"]},
          "postprocess_record_sha256": {"type": ["string", "null"], "pattern": "^sha256:[a-f0-9]{64}$"},
          "reuse_authorization_ref": {"type": ["object", "null"]},
          "image2_runtime_profile": {"enum": ["not_applicable", "not_observable"]},
          "evidence_parity_result": {"enum": ["match", "not_applicable"]},
          "sidecar_path": {"type": "string"},
          "sidecar_sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
          "generation_record_path": {"type": "string"},
          "generation_record_sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
          "visual_review_ref": {"type": ["object", "null"]},
          "asset_status": {"enum": ["base_ready", "postprocess_pending", "review_pending", "review_pass", "blocked"]}
        }
      }
    },
    "delivery_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["visual_task_id", "base_asset_ref", "derived_rendition_refs", "required_postprocess", "delivery_asset_ref", "finalize_status"],
        "properties": {
          "visual_task_id": {"type": "string"},
          "base_asset_ref": {"type": "object"},
          "derived_rendition_refs": {"type": "array", "items": {"type": "object"}},
          "required_postprocess": {"type": "array", "uniqueItems": true, "items": {"enum": ["deterministic_overlay", "source_annotation", "crop", "platform_reframe"]}},
          "delivery_asset_ref": {"type": ["object", "null"]},
          "finalize_status": {"enum": ["ready_to_finalize", "postprocess_pending", "review_pending", "blocked"]}
        }
      }
    },
    "provider_task_count": {"type": "integer", "minimum": 0},
    "provider_attempt_count": {"type": "integer", "minimum": 0},
    "provider_invocation_count": {"type": "integer", "minimum": 0},
    "source_capture_attempt_count": {"type": "integer", "minimum": 0},
    "postprocess_count": {"type": "integer", "minimum": 0},
    "asset_set_status": {"enum": ["materialized_waiting_finalize", "ready_with_warnings_waiting_finalize", "waiting_assets", "blocked"]},
    "next_skill": {"const": "visual-asset-finalizer"}
  }
}
