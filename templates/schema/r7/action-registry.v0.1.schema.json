{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/r7/action-registry/v0.1",
  "title": "R7 delivery action registry v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "registry_id", "status", "actions"],
  "properties": {
    "schema_id": {"const": "taoge://registries/r7/actions/v0.1"},
    "schema_version": {"const": "0.1"},
    "registry_id": {"const": "r7-action-registry-v0.1"},
    "status": {"const": "active_compiled_h1"},
    "actions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/action"}}
  },
  "$defs": {
    "nonempty": {"type": "string", "minLength": 1},
    "action": {
      "type": "object", "additionalProperties": false,
      "required": ["action_code", "label", "allowed_target_types", "requires_target_artifact", "lifecycle_status", "introduced_contract"],
      "properties": {
        "action_code": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "label": {"$ref": "#/$defs/nonempty"},
        "allowed_target_types": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/nonempty"}},
        "requires_target_artifact": {"type": "boolean"},
        "lifecycle_status": {"enum": ["active", "historical"]},
        "introduced_contract": {"$ref": "#/$defs/nonempty"}
      }
    }
  }
}
