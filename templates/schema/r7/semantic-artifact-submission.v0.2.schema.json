{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/r7/semantic-artifact-submission/v0.2",
  "title": "R7 committable semantic artifact submission v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "submission_id", "task_envelope_id", "session_id", "plan_id", "node_id", "skill_ref", "attempt_no", "submitted_at", "input_binding_digest", "output_artifact_type", "output_contract_version", "output_artifact_id", "output_revision", "result_status", "requested_action", "source_artifact_ids", "quality_status", "delivery_eligibility", "check_ids", "payload", "evidence_refs", "idempotency_key", "write_intent", "requested_machine_writes"],
  "properties": {
    "schema_id": {"const": "taoge://schemas/r7/semantic-artifact-submission/v0.2"},
    "schema_version": {"const": "0.2"},
    "submission_id": {"$ref": "#/$defs/nonempty"},
    "task_envelope_id": {"$ref": "#/$defs/nonempty"},
    "session_id": {"$ref": "#/$defs/nonempty"},
    "plan_id": {"$ref": "#/$defs/nonempty"},
    "node_id": {"$ref": "#/$defs/nonempty"},
    "skill_ref": {"$ref": "#/$defs/nonempty"},
    "attempt_no": {"type": "integer", "minimum": 1},
    "submitted_at": {"type": "string", "format": "date-time"},
    "input_binding_digest": {"$ref": "#/$defs/digest"},
    "output_artifact_type": {"$ref": "#/$defs/nonempty"},
    "output_contract_version": {"$ref": "#/$defs/nonempty"},
    "output_artifact_id": {"$ref": "#/$defs/nonempty"},
    "output_revision": {"type": "integer", "minimum": 1},
    "result_status": {"$ref": "#/$defs/nonempty"},
    "requested_action": {"type": ["string", "null"]},
    "source_artifact_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/nonempty"}},
    "quality_status": {"enum": ["pass", "pass_with_warnings", "human_review_required", "fail", "not_run"]},
    "delivery_eligibility": {"enum": ["blocked", "trace_only", "preview_only", "ready_for_delivery", "ready_for_upload"]},
    "check_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonempty"}},
    "payload": {"type": "object"},
    "evidence_refs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonempty"}},
    "idempotency_key": {"$ref": "#/$defs/nonempty"},
    "write_intent": {"const": "submit_for_deterministic_commit"},
    "requested_machine_writes": {"type": "array", "maxItems": 0}
  },
  "$defs": {
    "nonempty": {"type": "string", "minLength": 1},
    "digest": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
