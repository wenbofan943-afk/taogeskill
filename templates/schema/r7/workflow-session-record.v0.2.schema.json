{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/r7/workflow-session-record/v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "session_record_id", "session_id", "final_delivery_ref", "viewport_report_ref", "decision_status", "requested_action", "target_artifact_ref", "delivery_revision_request_ref", "decided_by", "decided_at", "next_skill"],
  "properties": {
    "schema_id": {"const": "taoge://schemas/r7/workflow-session-record/v0.2"},
    "schema_version": {"const": "0.2"},
    "session_record_id": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "minLength": 1},
    "final_delivery_ref": {"type": "object"},
    "viewport_report_ref": {"type": "object"},
    "decision_status": {"enum": ["human_confirm", "revision_requested", "export_requested", "archive_requested"]},
    "requested_action": {"enum": ["publish_all_manually", "revise_delivery", "export_handoff", "archive_session"]},
    "target_artifact_ref": {"type": ["object", "null"]},
    "delivery_revision_request_ref": {"type": ["object", "null"]},
    "decided_by": {"const": "human"},
    "decided_at": {"type": "string", "format": "date-time"},
    "next_skill": {"enum": ["done", "semantic-workflow-coordinator", "handoff-exporter", "archive-session"]}
  }
}
