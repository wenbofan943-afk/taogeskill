{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/r7/compatibility-matrix/v0.3",
  "title": "R7 compatibility matrix contract v0.3",
  "type": "object",
  "additionalProperties": false,
  "required": ["matrix_id", "matrix_version", "status", "entries"],
  "properties": {
    "matrix_id": {"const": "R7-CONTRACT-COMPATIBILITY-v0.3"},
    "matrix_version": {"const": "0.3"},
    "status": {"const": "joint_visual_revision_compiled_real_regression_pending"},
    "entries": {
      "type": "array",
      "minItems": 5,
      "items": {"$ref": "#/$defs/entry"}
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow_contract", "plan_contract", "delivery_contract", "registry_binding", "new_session_status", "resume_status", "replay_readable", "migration_required", "reason"],
      "properties": {
        "workflow_contract": {"type": "string", "minLength": 1},
        "plan_contract": {"type": "string", "minLength": 1},
        "delivery_contract": {"type": "string", "minLength": 1},
        "registry_binding": {"type": "string", "minLength": 1},
        "new_session_status": {"enum": ["active_offline_fixture_real_regression_pending", "forbidden_superseded", "forbidden_legacy"]},
        "resume_status": {"enum": ["active_same_contract", "replay_only"]},
        "replay_readable": {"const": true},
        "migration_required": {"type": "boolean"},
        "reason": {"type": "string", "minLength": 1}
      }
    }
  }
}
