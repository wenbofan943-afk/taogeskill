{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"taoge://schemas/r7/body-image-rendition-request/v0.1",
  "type":"object","additionalProperties":false,
  "required":["schema_id","schema_version","operation_id","session_id","rendition_id","source_asset_ref","target_canvas","output_relative_path","record_relative_path","requested_at"],
  "properties":{
    "schema_id":{"const":"taoge://schemas/r7/body-image-rendition-request/v0.1"},"schema_version":{"const":"0.1"},
    "operation_id":{"enum":["crop_fit_pad","platform_rendition"]},"session_id":{"type":"string","minLength":1},"rendition_id":{"type":"string","minLength":1},
    "source_asset_ref":{"type":"object","additionalProperties":false,"required":["artifact_id","relative_path","sha256"],"properties":{"artifact_id":{"type":"string","minLength":1},"relative_path":{"type":"string","minLength":1},"sha256":{"type":"string","pattern":"^(sha256:)?[a-f0-9]{64}$"}}},
    "target_canvas":{"type":"object","additionalProperties":false,"required":["width_px","height_px"],"properties":{"width_px":{"type":"integer","minimum":320},"height_px":{"type":"integer","minimum":320}}},
    "output_relative_path":{"type":"string","minLength":1},"record_relative_path":{"type":"string","minLength":1},"requested_at":{"type":"string","format":"date-time"}
  }
}
