{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/r7/image-asset-delivery-set/v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "delivery_asset_set_id", "image_asset_set_ref", "session_id", "delivery_assets", "finalize_record_refs", "delivery_asset_count", "finalize_status", "next_skill"],
  "properties": {
    "schema_id": {"const": "taoge://schemas/r7/image-asset-delivery-set/v0.1"},
    "schema_version": {"const": "0.1"},
    "delivery_asset_set_id": {"type": "string", "minLength": 1},
    "image_asset_set_ref": {"type": "object"},
    "session_id": {"type": "string", "minLength": 1},
    "delivery_assets": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["visual_task_id", "base_asset_ref", "delivery_asset_ref", "required_postprocess", "visual_review_ref"]}},
    "finalize_record_refs": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "delivery_asset_count": {"type": "integer", "minimum": 1},
    "finalize_status": {"enum": ["finalized", "finalized_with_warnings", "blocked"]},
    "next_skill": {"const": "copywriting-quality-review"}
  }
}
