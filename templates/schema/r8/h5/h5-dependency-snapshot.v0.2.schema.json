{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/r8/h5/h5-dependency-snapshot/v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "snapshot_id",
    "evaluation_id",
    "attempt_id",
    "semantic_case_id",
    "arm_role",
    "isolation_level",
    "source_commit",
    "entry_skill_path",
    "files",
    "closure_digest",
    "snapshot_status",
    "created_at",
    "supersedes"
  ],
  "properties": {
    "schema_id": { "const": "taoge://schemas/r8/h5/h5-dependency-snapshot/v0.2" },
    "schema_version": { "const": "0.2" },
    "snapshot_id": { "type": "string", "minLength": 1 },
    "evaluation_id": { "type": "string", "minLength": 1 },
    "attempt_id": { "type": "string", "minLength": 1 },
    "semantic_case_id": { "type": "string", "minLength": 1 },
    "arm_role": { "enum": [ "baseline", "candidate" ] },
    "isolation_level": {
      "enum": [
        "instruction_isolated",
        "read_audited",
        "capability_isolated"
      ]
    },
    "source_commit": { "type": "string", "minLength": 7 },
    "entry_skill_path": { "type": "string", "minLength": 1 },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [ "relative_path", "role", "sha256" ],
        "properties": {
          "relative_path": { "type": "string", "minLength": 1 },
          "role": {
            "enum": [
              "skill_entry",
              "contract",
              "reference",
              "asset",
              "machine_truth"
            ]
          },
          "sha256": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          }
        }
      }
    },
    "closure_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "snapshot_status": {
      "enum": [ "ready", "invalid", "superseded" ]
    },
    "created_at": { "type": "string", "minLength": 1 },
    "supersedes": { "type": [ "string", "null" ] }
  }
}
