{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/r8/h5/h5-human-verdict/v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "human_verdict_id",
    "evaluation_id",
    "attempt_id",
    "semantic_case_id",
    "blind_pair_ref",
    "reviewer_role",
    "choice",
    "business_reason",
    "verdict_status",
    "submitted_at",
    "verdict_digest",
    "supersedes"
  ],
  "properties": {
    "schema_id": { "const": "taoge://schemas/r8/h5/h5-human-verdict/v0.2" },
    "schema_version": { "const": "0.2" },
    "human_verdict_id": { "type": "string", "minLength": 1 },
    "evaluation_id": { "type": "string", "minLength": 1 },
    "attempt_id": { "type": "string", "minLength": 1 },
    "semantic_case_id": { "type": "string", "minLength": 1 },
    "blind_pair_ref": { "type": "string", "minLength": 1 },
    "reviewer_role": { "const": "human_owner" },
    "choice": { "enum": [ "A", "B", "tie" ] },
    "business_reason": { "type": "string", "minLength": 1 },
    "verdict_status": { "enum": [ "committed", "invalid", "superseded" ] },
    "submitted_at": { "type": "string", "minLength": 1 },
    "verdict_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "supersedes": { "type": [ "string", "null" ] }
  }
}
