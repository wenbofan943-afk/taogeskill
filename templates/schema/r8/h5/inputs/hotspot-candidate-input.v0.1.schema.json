{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/r8/h5/inputs/hotspot-candidate/v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id","schema_version","skill_id","arm_role","semantic_case_id","semantic_case_digest","semantic_projection_digest","contract_version","artifact_type","consumer_input","shared_outcome_invariants"],
  "properties": {
    "schema_id": {"const":"taoge://schemas/r8/h5/inputs/hotspot-candidate/v0.1"},
    "schema_version": {"const":"0.1"},
    "skill_id": {"const":"hotspot-topic-research"},
    "arm_role": {"const":"candidate"},
    "semantic_case_id": {"type":"string","minLength":1},
    "semantic_case_digest": {"type":"string","pattern":"^sha256:[a-f0-9]{64}$"},
    "semantic_projection_digest": {"type":"string","pattern":"^sha256:[a-f0-9]{64}$"},
    "contract_version": {"const":"0.3.0+r7-hotspot-v0.6"},
    "artifact_type": {"const":"hotspot_research_request"},
    "consumer_input": {
      "type":"object","additionalProperties":false,
      "required":["task_envelope","hotspot_research_request","source_observations"],
      "properties":{"task_envelope":{"type":"object"},"hotspot_research_request":{"type":"object"},"source_observations":{"type":"array"}}
    },
    "shared_outcome_invariants": {"type":"array","minItems":1,"items":{"type":"string","minLength":1}}
  }
}
