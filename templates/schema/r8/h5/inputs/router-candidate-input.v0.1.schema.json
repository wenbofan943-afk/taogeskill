{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/r8/h5/inputs/router-candidate/v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id","schema_version","skill_id","arm_role","semantic_case_id","semantic_case_digest","semantic_projection_digest","contract_version","artifact_type","consumer_input","shared_outcome_invariants"],
  "properties": {
    "schema_id": {"const":"taoge://schemas/r8/h5/inputs/router-candidate/v0.1"},
    "schema_version": {"const":"0.1"},
    "skill_id": {"const":"propagation-router"},
    "arm_role": {"const":"candidate"},
    "semantic_case_id": {"type":"string","minLength":1},
    "semantic_case_digest": {"type":"string","pattern":"^sha256:[a-f0-9]{64}$"},
    "semantic_projection_digest": {"type":"string","pattern":"^sha256:[a-f0-9]{64}$"},
    "contract_version": {"const":"0.6.0"},
    "artifact_type": {"const":"entry_router_request"},
    "consumer_input": {
      "type":"object","additionalProperties":false,
      "required":["entry_router_request","active_workflow_plan","current_workflow_state","current_artifact"],
      "properties":{"entry_router_request":{"type":"object"},"active_workflow_plan":{"type":"object"},"current_workflow_state":{"type":"object"},"current_artifact":{"type":["object","null"]}}
    },
    "shared_outcome_invariants": {"type":"array","minItems":1,"items":{"type":"string","minLength":1}}
  }
}
