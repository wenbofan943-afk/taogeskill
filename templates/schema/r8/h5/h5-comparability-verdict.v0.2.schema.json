{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/r8/h5/h5-comparability-verdict/v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "comparability_verdict_id",
    "evaluation_id",
    "attempt_id",
    "semantic_case_id",
    "machine_verdict_ref",
    "baseline_arm_result_ref",
    "candidate_arm_result_ref",
    "comparability_status",
    "baseline_primary_output_type",
    "candidate_primary_output_type",
    "reason_codes",
    "blind_pair_allowed",
    "decided_at",
    "supersedes"
  ],
  "properties": {
    "schema_id": { "const": "taoge://schemas/r8/h5/h5-comparability-verdict/v0.2" },
    "schema_version": { "const": "0.2" },
    "comparability_verdict_id": { "type": "string", "minLength": 1 },
    "evaluation_id": { "type": "string", "minLength": 1 },
    "attempt_id": { "type": "string", "minLength": 1 },
    "semantic_case_id": { "type": "string", "minLength": 1 },
    "machine_verdict_ref": { "type": "string", "minLength": 1 },
    "baseline_arm_result_ref": { "type": "string", "minLength": 1 },
    "candidate_arm_result_ref": { "type": "string", "minLength": 1 },
    "comparability_status": {
      "enum": [
        "comparable",
        "behavior_only",
        "regression_disposition",
        "insufficient_comparable_samples",
        "invalid"
      ]
    },
    "baseline_primary_output_type": { "type": [ "string", "null" ] },
    "candidate_primary_output_type": { "type": [ "string", "null" ] },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "blind_pair_allowed": { "type": "boolean" },
    "decided_at": { "type": "string", "minLength": 1 },
    "supersedes": { "type": [ "string", "null" ] }
  }
}
