{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/final-delivery/typed-components/v0.6",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "final_delivery_id", "session_id", "candidate_status", "action_registry_version", "presentation_registry_version", "compiler_provenance", "source_map", "source_binding_digest", "artifact_execution_contribution", "delivery_payload"],
  "properties": {
    "schema_id": {"const": "taoge://schemas/final-delivery/typed-components/v0.6"},
    "schema_version": {"const": "typed_components_v0.6"},
    "final_delivery_id": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "minLength": 1},
    "candidate_status": {"enum": ["compiled", "compiled_with_warnings", "blocked"]},
    "action_registry_version": {"const": "r7-action-registry-v0.1"},
    "presentation_registry_version": {"const": "r7-delivery-presentation-registry-v0.1"},
    "compiler_provenance": {"type": "object", "required": ["producer", "compiler_version", "compiled_at"], "properties": {"producer": {"const": "deterministic_compiler"}, "compiler_version": {"const": "p0-deterministic-delivery-candidate-compiler-v0.6"}, "compiled_at": {"type": "string", "format": "date-time"}}},
    "source_map": {"type": "array", "minItems": 12, "items": {"type": "object", "required": ["artifact_type", "artifact_id", "relative_path", "sha256", "producer_event_id"], "properties": {"artifact_type": {"type": "string", "minLength": 1}, "artifact_id": {"type": "string", "minLength": 1}, "relative_path": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"}, "producer_event_id": {"type": "string", "minLength": 1}}}},
    "source_binding_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "artifact_execution_contribution": {"type": "object", "required": ["candidate_producer", "manual_patch_detected", "semantic_skill_step_completed_count", "deterministic_tool_step_completed_count", "human_gate_completed_count", "external_side_effect_step_completed_count", "agent_orchestrated_node_count"], "properties": {"candidate_producer": {"const": "deterministic_compiler"}, "manual_patch_detected": {"type": "boolean"}, "semantic_skill_step_completed_count": {"type": "integer", "minimum": 0}, "deterministic_tool_step_completed_count": {"type": "integer", "minimum": 0}, "human_gate_completed_count": {"type": "integer", "minimum": 0}, "external_side_effect_step_completed_count": {"type": "integer", "minimum": 0}, "agent_orchestrated_node_count": {"type": "integer", "minimum": 0}}},
    "delivery_payload": {"type": "object", "description": "Strictly validated typed_components_v0.5 compatibility presentation payload; v0.6 owns producer identity, source map and execution contribution."}
  }
}
