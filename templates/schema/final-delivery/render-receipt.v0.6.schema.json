{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/final-delivery/render-receipt/v0.6",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "receipt_id", "delivery_revision_id", "candidate_sha256", "delivery_payload_sha256", "renderer_version", "template_bundle_sha256", "output_html_sha256", "rendered_at"],
  "properties": {
    "schema_id": {"const": "taoge://schemas/final-delivery/render-receipt/v0.6"},
    "schema_version": {"const": "0.6"},
    "receipt_id": {"type": "string", "minLength": 1},
    "delivery_revision_id": {"type": "string", "minLength": 1},
    "candidate_sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "delivery_payload_sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "renderer_version": {"const": "final-delivery-renderer-v0.6"},
    "template_bundle_sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "output_html_sha256": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "rendered_at": {"type": "string", "format": "date-time"}
  }
}
