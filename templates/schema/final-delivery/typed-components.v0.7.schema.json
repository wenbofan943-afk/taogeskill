{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/final-delivery/typed-components/v0.7",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "final_delivery_id", "session_id", "candidate_status", "action_registry_version", "presentation_registry_version", "compiler_provenance", "content_source_context", "source_map", "source_binding_digest", "artifact_execution_contribution", "external_activity_counts", "delivery_payload"],
  "properties": {
    "schema_id": {"const": "taoge://schemas/final-delivery/typed-components/v0.7"},
    "schema_version": {"const": "typed_components_v0.7"},
    "final_delivery_id": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "minLength": 1},
    "candidate_status": {"enum": ["compiled", "compiled_with_warnings", "blocked"]},
    "action_registry_version": {"const": "r7-action-registry-v0.2"},
    "presentation_registry_version": {"const": "r7-delivery-presentation-registry-v0.2"},
    "compiler_provenance": {"type": "object", "additionalProperties": false, "required": ["producer", "compiler_version", "compiled_at"], "properties": {"producer": {"const": "deterministic_compiler"}, "compiler_version": {"const": "p0-deterministic-delivery-candidate-compiler-v0.7"}, "compiled_at": {"type": "string", "format": "date-time"}}},
    "content_source_context": {"$ref": "#/$defs/contentSourceContext"},
    "source_map": {"type": "array", "minItems": 12, "items": {"$ref": "#/$defs/sourceMapItem"}},
    "source_binding_digest": {"$ref": "#/$defs/digest"},
    "artifact_execution_contribution": {"type": "object", "required": ["candidate_producer", "manual_patch_detected", "semantic_skill_step_completed_count", "deterministic_tool_step_completed_count", "human_gate_completed_count", "external_side_effect_step_completed_count", "agent_orchestrated_node_count"]},
    "external_activity_counts": {"type": "object", "additionalProperties": false, "required": ["network_read_count", "source_capture_attempt_count", "image_provider_attempt_count", "external_side_effect_step_completed_count"], "properties": {"network_read_count": {"type": "integer", "minimum": 0}, "source_capture_attempt_count": {"type": "integer", "minimum": 0}, "image_provider_attempt_count": {"type": "integer", "minimum": 0}, "external_side_effect_step_completed_count": {"type": "integer", "minimum": 0}}},
    "delivery_payload": {"type": "object"}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "artifactRef": {"type": "object", "additionalProperties": false, "required": ["artifact_id", "revision", "sha256"], "properties": {"artifact_id": {"type": "string", "minLength": 1}, "revision": {"type": "integer", "minimum": 1}, "sha256": {"$ref": "#/$defs/digest"}}},
    "sourceMapItem": {"type": "object", "additionalProperties": false, "required": ["artifact_type", "artifact_id", "relative_path", "sha256", "producer_event_id"], "properties": {"artifact_type": {"type": "string", "minLength": 1}, "artifact_id": {"type": "string", "minLength": 1}, "relative_path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/digest"}, "producer_event_id": {"type": "string", "minLength": 1}}},
    "contentSourceContext": {
      "oneOf": [
        {"type": "object", "additionalProperties": false, "required": ["content_origin", "content_source_ref", "research_set_ref", "selection_decision_ref", "selected_topic_source_ref", "freshness_review_ref"], "properties": {"content_origin": {"const": "user_supplied_draft"}, "content_source_ref": {"$ref": "#/$defs/artifactRef"}, "research_set_ref": {"type": "null"}, "selection_decision_ref": {"type": "null"}, "selected_topic_source_ref": {"type": "null"}, "freshness_review_ref": {"type": "null"}}},
        {"type": "object", "additionalProperties": false, "required": ["content_origin", "content_source_ref", "research_set_ref", "selection_decision_ref", "selected_topic_source_ref", "freshness_review_ref"], "properties": {"content_origin": {"const": "hotspot_selected_topic"}, "content_source_ref": {"$ref": "#/$defs/artifactRef"}, "research_set_ref": {"$ref": "#/$defs/artifactRef"}, "selection_decision_ref": {"$ref": "#/$defs/artifactRef"}, "selected_topic_source_ref": {"$ref": "#/$defs/artifactRef"}, "freshness_review_ref": {"$ref": "#/$defs/artifactRef"}}}
      ]
    }
  }
}
