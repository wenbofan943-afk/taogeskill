{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/p0/session-execution-plan/v0.6",
  "title": "R7 semantic single-content workflow plan v0.6",
  "type": "object",
  "additionalProperties": false,
  "required": ["plan_id", "session_id", "workflow_definition_version", "contract_bundle_version", "plan_schema_id", "event_schema_id", "artifact_lineage_schema_id", "render_input_schema_id", "renderer_version", "template_version", "runtime_mode", "topic_count", "final_delivery_count", "blueprint_id", "blueprint_version", "steps"],
  "properties": {
    "plan_id": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "minLength": 1},
    "workflow_definition_version": {"const": "r7-single-semantic-workflow-v0.1"},
    "contract_bundle_version": {"const": "p0-contract-bundle-v0.6"},
    "plan_schema_id": {"const": "taoge://schemas/p0/session-execution-plan/v0.6"},
    "event_schema_id": {"const": "taoge://schemas/p0/execution-event/v0.2"},
    "artifact_lineage_schema_id": {"const": "taoge://schemas/p0/artifact-lineage/v0.2"},
    "render_input_schema_id": {"const": "taoge://schemas/final-delivery/typed-components/v0.6"},
    "renderer_version": {"const": "final-delivery-renderer-v0.6"},
    "template_version": {"const": "final-delivery-template-v0.6"},
    "runtime_mode": {"const": "single"},
    "topic_count": {"const": 1},
    "final_delivery_count": {"const": 1},
    "blueprint_id": {"type": "string", "minLength": 1},
    "blueprint_version": {"const": "0.1"},
    "steps": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/step"}}
  },
  "$defs": {
    "retry": {"type": "object", "additionalProperties": false, "required": ["mode", "automatic_retries", "max_attempts", "idempotency_scope"], "properties": {
      "mode": {"enum": ["never", "bounded", "reconcile_first", "human_decision_required"]},
      "automatic_retries": {"type": "integer", "minimum": 0, "maximum": 1},
      "max_attempts": {"type": "integer", "minimum": 1, "maximum": 2},
      "idempotency_scope": {"const": "session_step_input_digest"}
    }},
    "step": {"type": "object", "additionalProperties": false, "required": ["step_id", "step_kind", "node_id", "skill_ref", "task_contract_version", "output_schema_ref", "requires_step_ids", "produces_artifact_type", "success_state", "failure_route", "retry_policy"], "properties": {
      "step_id": {"type": "string", "minLength": 1},
      "step_kind": {"enum": ["deterministic_tool", "agent_required", "human_gate", "external_side_effect"]},
      "operation": {"type": "string"},
      "node_id": {"type": "string", "minLength": 1},
      "skill_ref": {"type": "string", "minLength": 1},
      "task_contract_version": {"type": "string", "minLength": 1},
      "output_schema_ref": {"type": "string", "minLength": 1},
      "requires_step_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
      "requires_artifact_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
      "produces_artifact_type": {"type": "string", "minLength": 1},
      "success_state": {"const": "succeeded"},
      "failure_route": {"type": "string", "minLength": 1},
      "retry_policy": {"$ref": "#/$defs/retry"}
    }}
  }
}
