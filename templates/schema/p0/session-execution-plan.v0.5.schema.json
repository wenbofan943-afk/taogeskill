{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/p0/session-execution-plan/v0.5",
  "title": "Taoge P0 script-structure and visual-coverage delivery plan v0.5",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "plan_id", "session_id", "workflow_definition_version", "contract_bundle_version",
    "plan_schema_id", "event_schema_id", "artifact_lineage_schema_id",
    "render_input_schema_id", "renderer_version", "template_version",
    "runtime_mode", "topic_count", "final_delivery_count", "steps"
  ],
  "properties": {
    "plan_id": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "minLength": 1},
    "workflow_definition_version": {"const": "p0-single-runtime-v0.2"},
    "contract_bundle_version": {"const": "p0-contract-bundle-v0.5"},
    "plan_schema_id": {"const": "taoge://schemas/p0/session-execution-plan/v0.5"},
    "event_schema_id": {"const": "taoge://schemas/p0/execution-event/v0.2"},
    "artifact_lineage_schema_id": {"const": "taoge://schemas/p0/artifact-lineage/v0.2"},
    "render_input_schema_id": {"const": "taoge://schemas/final-delivery/typed-components/v0.5"},
    "renderer_version": {"const": "final-delivery-renderer-v0.5"},
    "template_version": {"const": "final-delivery-template-v0.5"},
    "runtime_mode": {"const": "single"},
    "topic_count": {"const": 1},
    "final_delivery_count": {"const": 1},
    "steps": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/step"}}
  },
  "$defs": {
    "retryPolicy": {
      "type": "object", "additionalProperties": false,
      "required": ["mode", "automatic_retries", "max_attempts", "idempotency_scope"],
      "properties": {
        "mode": {"enum": ["never", "bounded", "reconcile_first", "human_decision_required"]},
        "automatic_retries": {"type": "integer", "minimum": 0, "maximum": 1},
        "max_attempts": {"type": "integer", "minimum": 1, "maximum": 2},
        "idempotency_scope": {"const": "session_step_input_digest"}
      }
    },
    "step": {
      "type": "object", "additionalProperties": false,
      "required": ["step_id", "step_kind", "failure_route", "retry_policy"],
      "properties": {
        "step_id": {"type": "string", "minLength": 1},
        "step_kind": {"enum": ["deterministic_tool", "agent_required", "human_gate", "external_side_effect"]},
        "operation": {"type": "string", "minLength": 1},
        "requires_step_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "requires_artifact_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "produces_artifact_type": {"type": "string", "minLength": 1},
        "success_state": {"const": "succeeded"},
        "failure_route": {"type": "string", "minLength": 1},
        "retry_policy": {"$ref": "#/$defs/retryPolicy"}
      },
      "allOf": [
        {"if": {"properties": {"step_kind": {"const": "deterministic_tool"}}}, "then": {"required": ["operation"], "properties": {"retry_policy": {"oneOf": [
          {"properties": {"mode": {"const": "never"}, "automatic_retries": {"const": 0}, "max_attempts": {"const": 1}}},
          {"properties": {"mode": {"const": "bounded"}, "automatic_retries": {"const": 1}, "max_attempts": {"const": 2}}}
        ]}}}},
        {"if": {"properties": {"step_kind": {"enum": ["agent_required", "human_gate"]}}}, "then": {"properties": {"retry_policy": {"properties": {"mode": {"const": "never"}, "automatic_retries": {"const": 0}, "max_attempts": {"const": 1}}}}}},
        {"if": {"properties": {"step_kind": {"const": "external_side_effect"}}}, "then": {"properties": {"retry_policy": {"properties": {"mode": {"enum": ["reconcile_first", "human_decision_required"]}, "automatic_retries": {"const": 0}, "max_attempts": {"const": 1}}}}}}
      ]
    }
  }
}
