{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/final-delivery/typed-components/v0.3",
  "title": "P0 H7 typed final delivery input v0.3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id", "schema_version", "render_input_id", "final_delivery_id",
    "account_name", "session_id", "research_run_id", "template_version", "generated_at",
    "topic", "script_card", "production_status", "delivery_revision", "run_provenance",
    "duration_estimate", "warning_items", "cover_cards", "pip_cards", "platform_cards",
    "platform_delivery_units", "trace_cards", "action_cards", "source_artifact_ids"
  ],
  "properties": {
    "schema_id": {"const": "taoge://schemas/final-delivery/typed-components/v0.3"},
    "schema_version": {"const": "typed_components_v0.3"},
    "render_input_id": {"type": "string", "minLength": 1},
    "final_delivery_id": {"type": "string", "minLength": 1},
    "account_name": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "minLength": 1},
    "research_run_id": {"type": "string", "minLength": 1},
    "template_version": {"const": "final-delivery-template-v0.3"},
    "generated_at": {"type": "string", "format": "date-time"},
    "topic": {
      "type": "object", "additionalProperties": false,
      "required": ["title", "why_now", "content_format"],
      "properties": {
        "title": {"type": "string", "minLength": 1},
        "why_now": {"type": "string", "minLength": 1},
        "content_format": {"type": "string", "minLength": 1}
      }
    },
    "script_card": {
      "type": "object", "additionalProperties": false,
      "required": ["card_id", "card_type", "status", "source_artifact_ids", "final_text", "copy_label", "source_draft_id", "character_count"],
      "properties": {
        "card_id": {"type": "string", "minLength": 1},
        "card_type": {"const": "script"},
        "status": {"enum": ["ready", "ready_with_warnings", "needs_action", "blocked"]},
        "source_artifact_ids": {"$ref": "#/$defs/stringArray"},
        "hook_text": {"type": "string"},
        "final_text": {"type": "string", "minLength": 1},
        "copy_label": {"type": "string", "minLength": 1},
        "source_draft_id": {"type": "string", "minLength": 1},
        "character_count": {"type": "integer", "minimum": 1},
        "revision_note": {"type": "string"}
      }
    },
    "production_status": {
      "type": "object", "additionalProperties": false,
      "required": ["image_assets_status", "cover_quality_status", "overall_quality_status", "delivery_readiness", "derived_by", "warning_codes"],
      "properties": {
        "image_assets_status": {"type": "string", "minLength": 1},
        "cover_quality_status": {"enum": ["pass", "pass_with_warnings", "fail", "not_run", "not_applicable"]},
        "overall_quality_status": {"enum": ["pass", "pass_with_warnings", "fail", "not_run"]},
        "delivery_readiness": {"enum": ["ready", "ready_with_warnings", "needs_action", "blocked"]},
        "derived_by": {"const": "derive_delivery_readiness_v0.3"},
        "warning_codes": {"$ref": "#/$defs/stringArray"}
      }
    },
    "delivery_revision": {
      "type": "object", "additionalProperties": false,
      "required": ["delivery_revision_id", "revision_no", "revision_status", "source_artifact_bindings", "generated_view_paths", "semantic_gate_status"],
      "properties": {
        "delivery_revision_id": {"type": "string", "minLength": 1},
        "revision_no": {"type": "integer", "minimum": 1},
        "revision_status": {"enum": ["preparing", "compiled", "current", "superseded", "blocked"]},
        "supersedes_delivery_revision_id": {"type": "string", "minLength": 1},
        "semantic_gate_status": {"enum": ["pending", "pass", "blocked"]},
        "source_artifact_bindings": {
          "type": "array", "minItems": 5,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["artifact_type", "artifact_id", "sha256"],
            "properties": {
              "artifact_type": {"type": "string", "minLength": 1},
              "artifact_id": {"type": "string", "minLength": 1},
              "sha256": {"$ref": "#/$defs/digest"}
            }
          }
        },
        "generated_view_paths": {
          "type": "object", "additionalProperties": false,
          "required": ["final_html", "final_script", "final_visual_plan", "final_platform_package", "content_delivery_record", "revision_manifest"],
          "properties": {
            "final_html": {"type": "string", "minLength": 1},
            "final_script": {"type": "string", "minLength": 1},
            "final_visual_plan": {"type": "string", "minLength": 1},
            "final_platform_package": {"type": "string", "minLength": 1},
            "content_delivery_record": {"type": "string", "minLength": 1},
            "revision_manifest": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "run_provenance": {
      "type": "object", "additionalProperties": false,
      "required": ["run_purpose", "reused_content", "reused_research", "executed_scopes", "not_executed_scopes", "user_summary"],
      "properties": {
        "run_purpose": {"enum": ["content_production", "regression", "revision"]},
        "reused_content": {"type": "boolean"},
        "reused_research": {"type": "boolean"},
        "executed_scopes": {"$ref": "#/$defs/stringArray"},
        "not_executed_scopes": {"$ref": "#/$defs/stringArray"},
        "user_summary": {"type": "string", "minLength": 1}
      }
    },
    "duration_estimate": {
      "type": "object", "additionalProperties": false,
      "required": ["duration_estimate_status", "source_text_digest"],
      "properties": {
        "duration_estimate_status": {"enum": ["measured", "derived_range", "not_available"]},
        "source_text_digest": {"$ref": "#/$defs/digest"},
        "measured_duration_seconds": {"type": "integer", "minimum": 1},
        "estimated_duration_min_seconds": {"type": "integer", "minimum": 1},
        "estimated_duration_max_seconds": {"type": "integer", "minimum": 1},
        "speech_rate_profile": {"type": "string", "minLength": 1},
        "derivation_method": {"type": "string", "minLength": 1},
        "not_available_reason": {"type": "string", "minLength": 1}
      }
    },
    "warning_items": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["warning_code", "warning_category", "severity", "user_message", "impact", "recommended_action", "source_artifact_id", "resolution_status"],
        "properties": {
          "warning_code": {"type": "string", "minLength": 1},
          "warning_category": {"enum": ["research", "copy", "visual", "cover", "publishing", "runtime_scope"]},
          "severity": {"enum": ["blocking", "non_blocking", "known_scope"]},
          "user_message": {"type": "string", "minLength": 1},
          "impact": {"type": "string", "minLength": 1},
          "recommended_action": {"type": "string", "minLength": 1},
          "source_artifact_id": {"type": "string", "minLength": 1},
          "resolution_status": {"enum": ["open", "resolved", "accepted"]}
        }
      }
    },
    "cover_cards": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/coverCard"}},
    "cover_empty_reason": {"type": "string"},
    "pip_cards": {"type": "array", "items": {"$ref": "#/$defs/pipCard"}},
    "pip_empty_reason": {"type": "string"},
    "platform_cards": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/platformCard"}},
    "platform_delivery_units": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/platformUnit"}},
    "trace_cards": {"type": "array", "minItems": 5, "items": {"$ref": "#/$defs/traceCard"}},
    "action_cards": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/actionCard"}},
    "source_artifact_ids": {"$ref": "#/$defs/stringArray"}
  },
  "$defs": {
    "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "stringArray": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "cardBase": {
      "type": "object",
      "required": ["card_id", "card_type", "status", "source_artifact_ids"],
      "properties": {
        "card_id": {"type": "string", "minLength": 1},
        "card_type": {"type": "string", "minLength": 1},
        "status": {"enum": ["ready", "ready_with_warnings", "needs_action", "blocked", "trace_only"]},
        "source_artifact_ids": {"$ref": "#/$defs/stringArray"}
      }
    },
    "coverCard": {
      "allOf": [
        {"$ref": "#/$defs/cardBase"},
        {
          "type": "object", "additionalProperties": false,
          "required": ["card_id", "card_type", "display_order", "status", "source_artifact_ids", "cover_role", "platform", "title_text", "rendered_text", "asset_status", "asset_id", "relative_path", "sha256", "sidecar_path", "usage_note"],
          "properties": {
            "card_id": {"type": "string"}, "card_type": {"const": "cover"}, "display_order": {"type": "integer", "minimum": 1},
            "status": {"type": "string"}, "source_artifact_ids": {"$ref": "#/$defs/stringArray"},
            "cover_role": {"const": "platform_cover"}, "platform": {"type": "string"}, "title_text": {"type": "string", "minLength": 1},
            "rendered_text": {"type": "string", "minLength": 1}, "asset_status": {"enum": ["generated", "reused_verified"]},
            "asset_id": {"type": "string", "minLength": 1}, "relative_path": {"type": "string", "minLength": 1},
            "sha256": {"$ref": "#/$defs/digest"}, "sidecar_path": {"type": "string", "minLength": 1}, "usage_note": {"type": "string", "minLength": 1}
          }
        }
      ]
    },
    "pipCard": {
      "allOf": [
        {"$ref": "#/$defs/cardBase"},
        {
          "type": "object", "additionalProperties": false,
          "required": ["card_id", "card_type", "display_order", "status", "source_artifact_ids", "trigger_text", "insert_after_text", "insert_before_text", "narrative_function", "viewer_problem", "asset_status", "asset_id", "relative_path", "sha256", "sidecar_path", "prompt_path", "generation_record_path", "preview_alt", "visual_text_summary", "warning_codes"],
          "properties": {
            "card_id": {"type": "string"}, "card_type": {"const": "picture_in_picture"}, "display_order": {"type": "integer", "minimum": 1},
            "status": {"type": "string"}, "source_artifact_ids": {"$ref": "#/$defs/stringArray"},
            "trigger_text": {"type": "string", "minLength": 1}, "insert_after_text": {"type": "string", "minLength": 1}, "insert_before_text": {"type": "string", "minLength": 1},
            "narrative_function": {"type": "string", "minLength": 1}, "viewer_problem": {"type": "string", "minLength": 1},
            "asset_status": {"enum": ["generated", "reused_verified"]}, "asset_id": {"type": "string", "minLength": 1},
            "relative_path": {"type": "string", "minLength": 1}, "sha256": {"$ref": "#/$defs/digest"}, "sidecar_path": {"type": "string", "minLength": 1},
            "prompt_path": {"type": "string", "minLength": 1}, "generation_record_path": {"type": "string", "minLength": 1},
            "preview_alt": {"type": "string", "minLength": 1}, "visual_text_summary": {"type": "string", "minLength": 1}, "warning_codes": {"$ref": "#/$defs/stringArray"}
          }
        }
      ]
    },
    "platformCard": {
      "allOf": [
        {"$ref": "#/$defs/cardBase"},
        {
          "type": "object", "additionalProperties": false,
          "required": ["card_id", "card_type", "display_order", "status", "source_artifact_ids", "platform", "cover_title", "video_title", "publish_description", "hashtags", "publish_readiness"],
          "properties": {
            "card_id": {"type": "string"}, "card_type": {"const": "platform"}, "display_order": {"type": "integer", "minimum": 1},
            "status": {"type": "string"}, "source_artifact_ids": {"$ref": "#/$defs/stringArray"}, "platform": {"type": "string", "minLength": 1},
            "cover_title": {"type": "string", "minLength": 1}, "video_title": {"type": "string", "minLength": 1}, "publish_description": {"type": "string", "minLength": 1},
            "hashtags": {"$ref": "#/$defs/stringArray"}, "publish_readiness": {"enum": ["ready", "ready_with_warnings", "blocked"]}
          }
        }
      ]
    },
    "platformUnit": {
      "type": "object", "additionalProperties": false,
      "required": ["unit_id", "display_order", "platform", "platform_label", "platform_card_id", "cover_card_id", "cover_title", "rendered_cover_text", "cover_asset_id", "cover_asset_path", "cover_sha256", "video_title", "publish_description", "hashtags", "publish_readiness"],
      "properties": {
        "unit_id": {"type": "string", "minLength": 1}, "display_order": {"type": "integer", "minimum": 1}, "platform": {"type": "string", "minLength": 1},
        "platform_label": {"type": "string", "minLength": 1}, "platform_card_id": {"type": "string", "minLength": 1}, "cover_card_id": {"type": "string", "minLength": 1},
        "cover_title": {"type": "string", "minLength": 1}, "rendered_cover_text": {"type": "string", "minLength": 1}, "cover_asset_id": {"type": "string", "minLength": 1},
        "cover_asset_path": {"type": "string", "minLength": 1}, "cover_sha256": {"$ref": "#/$defs/digest"}, "video_title": {"type": "string", "minLength": 1},
        "publish_description": {"type": "string", "minLength": 1}, "hashtags": {"$ref": "#/$defs/stringArray"}, "publish_readiness": {"enum": ["ready", "ready_with_warnings", "blocked"]}
      }
    },
    "traceCard": {
      "allOf": [
        {"$ref": "#/$defs/cardBase"},
        {
          "type": "object", "additionalProperties": false,
          "required": ["card_id", "card_type", "display_order", "status", "source_artifact_ids", "artifact_type", "artifact_id", "label", "relative_path", "materialization_status"],
          "properties": {
            "card_id": {"type": "string"}, "card_type": {"const": "trace"}, "display_order": {"type": "integer", "minimum": 1},
            "status": {"type": "string"}, "source_artifact_ids": {"$ref": "#/$defs/stringArray"}, "artifact_type": {"type": "string", "minLength": 1},
            "artifact_id": {"type": "string", "minLength": 1}, "label": {"type": "string", "minLength": 1}, "relative_path": {"type": "string", "minLength": 1},
            "materialization_status": {"enum": ["materialized", "pending"]}, "sha256": {"$ref": "#/$defs/digest"}
          }
        }
      ]
    },
    "actionCard": {
      "allOf": [
        {"$ref": "#/$defs/cardBase"},
        {
          "type": "object", "additionalProperties": false,
          "required": ["card_id", "card_type", "display_order", "status", "source_artifact_ids", "action", "label", "instruction", "reply_example", "is_primary"],
          "properties": {
            "card_id": {"type": "string"}, "card_type": {"const": "action"}, "display_order": {"type": "integer", "minimum": 1},
            "status": {"type": "string"}, "source_artifact_ids": {"$ref": "#/$defs/stringArray"}, "action": {"type": "string", "minLength": 1},
            "label": {"type": "string", "minLength": 1}, "instruction": {"type": "string", "minLength": 1}, "reply_example": {"type": "string", "minLength": 1},
            "target_artifact_id": {"type": "string", "minLength": 1}, "is_primary": {"type": "boolean"}
          }
        }
      ]
    }
  }
}
