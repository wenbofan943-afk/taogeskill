{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/final-delivery/typed-components/v0.4",
  "title": "P0 H7 typed final delivery input with visual surface evidence v0.4",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id", "schema_version", "render_input_id", "final_delivery_id", "account_name", "session_id",
    "research_run_id", "template_version", "generated_at", "topic", "script_card", "production_status",
    "delivery_revision", "run_provenance", "duration_estimate", "warning_items", "cover_cards",
    "visual_insert_cards", "platform_cards", "platform_delivery_units", "trace_cards", "action_cards", "source_artifact_ids"
  ],
  "properties": {
    "schema_id": {"const": "taoge://schemas/final-delivery/typed-components/v0.4"},
    "schema_version": {"const": "typed_components_v0.4"},
    "render_input_id": {"$ref": "#/$defs/nonempty"}, "final_delivery_id": {"$ref": "#/$defs/nonempty"},
    "account_name": {"$ref": "#/$defs/nonempty"}, "session_id": {"$ref": "#/$defs/nonempty"},
    "research_run_id": {"$ref": "#/$defs/nonempty"}, "template_version": {"const": "final-delivery-template-v0.4"},
    "generated_at": {"type": "string", "format": "date-time"},
    "topic": {"type": "object", "required": ["title", "why_now", "content_format"], "properties": {"title": {"$ref": "#/$defs/nonempty"}, "why_now": {"$ref": "#/$defs/nonempty"}, "content_format": {"$ref": "#/$defs/nonempty"}}},
    "script_card": {"type": "object", "required": ["card_id", "card_type", "status", "source_artifact_ids", "final_text", "copy_label", "source_draft_id", "character_count"], "properties": {"card_id": {"$ref": "#/$defs/nonempty"}, "card_type": {"const": "script"}, "status": {"enum": ["ready", "ready_with_warnings", "needs_action", "blocked"]}, "source_artifact_ids": {"$ref": "#/$defs/stringArray"}, "final_text": {"$ref": "#/$defs/nonempty"}, "copy_label": {"$ref": "#/$defs/nonempty"}, "source_draft_id": {"$ref": "#/$defs/nonempty"}, "character_count": {"type": "integer", "minimum": 1}, "hook_text": {"type": "string"}, "revision_note": {"type": "string"}}},
    "production_status": {
      "type": "object", "additionalProperties": false,
      "required": ["image_assets_status", "cover_quality_status", "overall_quality_status", "delivery_readiness", "platform_delivery_scope_status", "derived_by", "warning_codes"],
      "properties": {
        "image_assets_status": {"$ref": "#/$defs/nonempty"}, "cover_quality_status": {"enum": ["pass", "pass_with_warnings", "fail", "not_run", "not_applicable"]},
        "overall_quality_status": {"enum": ["pass", "pass_with_warnings", "fail", "not_run"]},
        "delivery_readiness": {"$ref": "#/$defs/deliveryScope"}, "platform_delivery_scope_status": {"$ref": "#/$defs/deliveryScope"},
        "derived_by": {"const": "derive_delivery_readiness_v0.4"}, "warning_codes": {"$ref": "#/$defs/stringArray"}
      }
    },
    "delivery_revision": {"$ref": "#/$defs/deliveryRevision"},
    "run_provenance": {"type": "object", "required": ["run_purpose", "reused_content", "reused_research", "executed_scopes", "not_executed_scopes", "user_summary"], "properties": {"run_purpose": {"enum": ["content_production", "regression", "revision"]}, "reused_content": {"type": "boolean"}, "reused_research": {"type": "boolean"}, "executed_scopes": {"$ref": "#/$defs/stringArray"}, "not_executed_scopes": {"$ref": "#/$defs/stringArray"}, "user_summary": {"$ref": "#/$defs/nonempty"}}},
    "duration_estimate": {"type": "object"},
    "warning_items": {"type": "array", "items": {"$ref": "#/$defs/warning"}},
    "cover_cards": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/coverCard"}},
    "visual_insert_cards": {"type": "array", "items": {"$ref": "#/$defs/visualInsertCard"}},
    "visual_insert_empty_reason": {"type": "string"},
    "platform_cards": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/platformCard"}},
    "platform_delivery_units": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/platformUnit"}},
    "trace_cards": {"type": "array", "minItems": 5, "items": {"type": "object"}},
    "action_cards": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "source_artifact_ids": {"$ref": "#/$defs/stringArray"}
  },
  "$defs": {
    "nonempty": {"type": "string", "minLength": 1},
    "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "stringArray": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonempty"}},
    "deliveryScope": {"enum": ["ready_all_target_platforms", "primary_ready_secondary_pending", "not_publish_ready"]},
    "ratio": {"type": "object", "additionalProperties": false, "required": ["ratio_width", "ratio_height", "orientation"], "properties": {"ratio_width": {"type": "integer", "minimum": 1}, "ratio_height": {"type": "integer", "minimum": 1}, "orientation": {"enum": ["portrait", "landscape", "square"]}}},
    "canvas": {"type": "object", "additionalProperties": false, "required": ["width_px", "height_px", "aspect_ratio"], "properties": {"width_px": {"type": "integer", "minimum": 1}, "height_px": {"type": "integer", "minimum": 1}, "aspect_ratio": {"$ref": "#/$defs/ratio"}}},
    "rect": {"type": "object", "additionalProperties": false, "required": ["x", "y", "width", "height"], "properties": {"x": {"type": "number", "minimum": 0, "maximum": 1}, "y": {"type": "number", "minimum": 0, "maximum": 1}, "width": {"type": "number", "exclusiveMinimum": 0, "maximum": 1}, "height": {"type": "number", "exclusiveMinimum": 0, "maximum": 1}}},
    "deliveryRevision": {
      "type": "object", "additionalProperties": false, "required": ["delivery_revision_id", "revision_no", "revision_status", "source_artifact_bindings", "generated_view_paths", "semantic_gate_status"],
      "properties": {
        "delivery_revision_id": {"$ref": "#/$defs/nonempty"}, "revision_no": {"type": "integer", "minimum": 1},
        "revision_status": {"enum": ["preparing", "compiled", "current", "superseded", "blocked"]}, "supersedes_delivery_revision_id": {"$ref": "#/$defs/nonempty"},
        "semantic_gate_status": {"enum": ["pending", "pass", "blocked"]},
        "source_artifact_bindings": {"type": "array", "minItems": 5, "items": {"type": "object", "required": ["artifact_type", "artifact_id", "sha256"], "properties": {"artifact_type": {"$ref": "#/$defs/nonempty"}, "artifact_id": {"$ref": "#/$defs/nonempty"}, "sha256": {"$ref": "#/$defs/digest"}}}},
        "generated_view_paths": {"type": "object", "required": ["final_html", "final_script", "final_visual_plan", "final_platform_package", "content_delivery_record", "revision_manifest"], "properties": {"final_html": {"$ref": "#/$defs/nonempty"}, "final_script": {"$ref": "#/$defs/nonempty"}, "final_visual_plan": {"$ref": "#/$defs/nonempty"}, "final_platform_package": {"$ref": "#/$defs/nonempty"}, "content_delivery_record": {"$ref": "#/$defs/nonempty"}, "revision_manifest": {"$ref": "#/$defs/nonempty"}}}
      }
    },
    "warning": {"type": "object", "required": ["warning_code", "warning_category", "severity", "user_message", "impact", "recommended_action", "source_artifact_id", "resolution_status"], "properties": {"warning_code": {"$ref": "#/$defs/nonempty"}, "warning_category": {"$ref": "#/$defs/nonempty"}, "severity": {"enum": ["blocking", "non_blocking", "known_scope"]}, "user_message": {"$ref": "#/$defs/nonempty"}, "impact": {"$ref": "#/$defs/nonempty"}, "recommended_action": {"$ref": "#/$defs/nonempty"}, "source_artifact_id": {"$ref": "#/$defs/nonempty"}, "resolution_status": {"enum": ["open", "resolved", "accepted"]}}},
    "coverCard": {
      "type": "object", "additionalProperties": false,
      "required": ["card_id", "card_type", "display_order", "status", "source_artifact_ids", "cover_role", "cover_job_id", "cover_rendition_id", "rendition_revision", "platform", "platform_priority", "surface_profile_id", "surface_profile_version", "surface_role", "profile_evidence_status", "adaptation_strategy", "title_text", "rendered_text", "asset_status", "asset_id", "relative_path", "sha256", "sidecar_path", "preview_evidence_type", "preview_path", "preview_sha256", "visual_review_record_path", "reviewer_type", "visual_review_status", "cover_delivery_status", "usage_note"],
      "properties": {
        "card_id": {"$ref": "#/$defs/nonempty"}, "card_type": {"const": "cover"}, "display_order": {"type": "integer", "minimum": 1},
        "status": {"enum": ["ready", "needs_action", "blocked"]}, "source_artifact_ids": {"$ref": "#/$defs/stringArray"}, "cover_role": {"const": "platform_cover"},
        "cover_job_id": {"$ref": "#/$defs/nonempty"}, "cover_rendition_id": {"$ref": "#/$defs/nonempty"}, "rendition_revision": {"type": "integer", "minimum": 1},
        "platform": {"$ref": "#/$defs/nonempty"}, "platform_priority": {"enum": ["primary", "secondary"]}, "surface_profile_id": {"$ref": "#/$defs/nonempty"}, "surface_profile_version": {"$ref": "#/$defs/nonempty"},
        "surface_role": {"enum": ["feed_cover", "profile_grid_cover", "share_cover"]}, "profile_evidence_status": {"enum": ["official_verified", "observed_verified", "provisional_not_verified"]},
        "adaptation_strategy": {"enum": ["reuse_native", "focal_crop", "fit_pad", "outpaint_extend", "independent_generation", "manual_required"]},
        "title_text": {"$ref": "#/$defs/nonempty"}, "rendered_text": {"$ref": "#/$defs/nonempty"}, "asset_status": {"enum": ["generated", "reused_verified"]},
        "asset_id": {"$ref": "#/$defs/nonempty"}, "relative_path": {"$ref": "#/$defs/nonempty"}, "sha256": {"$ref": "#/$defs/digest"}, "sidecar_path": {"$ref": "#/$defs/nonempty"},
        "preview_evidence_type": {"enum": ["deterministic_surface_mock", "manual_app_observed"]}, "preview_path": {"$ref": "#/$defs/nonempty"}, "preview_sha256": {"$ref": "#/$defs/digest"},
        "visual_review_record_path": {"$ref": "#/$defs/nonempty"}, "reviewer_type": {"enum": ["codex_visual_review", "human_visual_review", "not_available"]},
        "visual_review_status": {"enum": ["pass", "fail", "not_reviewed"]}, "cover_delivery_status": {"enum": ["visual_pass", "visual_fail", "waiting_visual_review"]}, "usage_note": {"$ref": "#/$defs/nonempty"}
      }
    },
    "visualInsertCard": {
      "type": "object", "additionalProperties": false,
      "required": ["card_id", "card_type", "display_order", "status", "source_artifact_ids", "visual_insert_task_id", "image_task_id", "presentation_mode", "platform_surface_profile_id", "video_canvas", "visual_asset_canvas", "placement_slot", "aspect_ratio_verification_status", "trigger_text", "insert_after_text", "insert_before_text", "narrative_function", "viewer_problem", "asset_status", "asset_id", "relative_path", "sha256", "sidecar_path", "prompt_path", "generation_record_path", "preview_alt", "visual_text_summary", "warning_codes"],
      "properties": {
        "card_id": {"$ref": "#/$defs/nonempty"}, "card_type": {"const": "visual_insert"}, "display_order": {"type": "integer", "minimum": 1}, "status": {"enum": ["ready", "ready_with_warnings", "needs_action", "blocked"]}, "source_artifact_ids": {"$ref": "#/$defs/stringArray"},
        "visual_insert_task_id": {"$ref": "#/$defs/nonempty"}, "image_task_id": {"$ref": "#/$defs/nonempty"}, "presentation_mode": {"enum": ["full_frame_replace", "speaker_plus_visual", "split_screen", "floating_card", "source_evidence_card", "background_plate"]}, "platform_surface_profile_id": {"$ref": "#/$defs/nonempty"},
        "video_canvas": {"$ref": "#/$defs/canvas"}, "visual_asset_canvas": {"$ref": "#/$defs/canvas"}, "placement_slot": {"$ref": "#/$defs/rect"}, "aspect_ratio_verification_status": {"const": "pass"},
        "trigger_text": {"$ref": "#/$defs/nonempty"}, "insert_after_text": {"$ref": "#/$defs/nonempty"}, "insert_before_text": {"$ref": "#/$defs/nonempty"}, "narrative_function": {"$ref": "#/$defs/nonempty"}, "viewer_problem": {"$ref": "#/$defs/nonempty"},
        "asset_status": {"enum": ["generated", "reused_verified"]}, "asset_id": {"$ref": "#/$defs/nonempty"}, "relative_path": {"$ref": "#/$defs/nonempty"}, "sha256": {"$ref": "#/$defs/digest"}, "sidecar_path": {"$ref": "#/$defs/nonempty"}, "prompt_path": {"$ref": "#/$defs/nonempty"}, "generation_record_path": {"$ref": "#/$defs/nonempty"}, "preview_alt": {"$ref": "#/$defs/nonempty"}, "visual_text_summary": {"$ref": "#/$defs/nonempty"}, "warning_codes": {"$ref": "#/$defs/stringArray"}
      }
    },
    "platformCard": {"type": "object", "required": ["card_id", "card_type", "display_order", "status", "source_artifact_ids", "platform", "platform_priority", "cover_title", "video_title", "publish_description", "hashtags", "publish_readiness"], "properties": {"card_id": {"$ref": "#/$defs/nonempty"}, "card_type": {"const": "platform"}, "display_order": {"type": "integer", "minimum": 1}, "status": {"enum": ["ready", "needs_action", "blocked"]}, "source_artifact_ids": {"$ref": "#/$defs/stringArray"}, "platform": {"$ref": "#/$defs/nonempty"}, "platform_priority": {"enum": ["primary", "secondary"]}, "cover_title": {"$ref": "#/$defs/nonempty"}, "video_title": {"$ref": "#/$defs/nonempty"}, "publish_description": {"$ref": "#/$defs/nonempty"}, "hashtags": {"$ref": "#/$defs/stringArray"}, "publish_readiness": {"enum": ["ready", "waiting_visual_review", "blocked"]}}},
    "platformUnit": {"type": "object", "required": ["unit_id", "display_order", "platform", "platform_label", "platform_priority", "platform_card_id", "cover_card_id", "surface_profile_id", "cover_rendition_id", "cover_title", "rendered_cover_text", "cover_asset_id", "cover_asset_path", "cover_sha256", "cover_preview_path", "cover_preview_sha256", "adaptation_strategy", "preview_evidence_type", "visual_review_status", "cover_delivery_status", "video_title", "publish_description", "hashtags", "publish_readiness"], "properties": {"unit_id": {"$ref": "#/$defs/nonempty"}, "display_order": {"type": "integer", "minimum": 1}, "platform": {"$ref": "#/$defs/nonempty"}, "platform_label": {"$ref": "#/$defs/nonempty"}, "platform_priority": {"enum": ["primary", "secondary"]}, "platform_card_id": {"$ref": "#/$defs/nonempty"}, "cover_card_id": {"$ref": "#/$defs/nonempty"}, "surface_profile_id": {"$ref": "#/$defs/nonempty"}, "cover_rendition_id": {"$ref": "#/$defs/nonempty"}, "cover_title": {"$ref": "#/$defs/nonempty"}, "rendered_cover_text": {"$ref": "#/$defs/nonempty"}, "cover_asset_id": {"$ref": "#/$defs/nonempty"}, "cover_asset_path": {"$ref": "#/$defs/nonempty"}, "cover_sha256": {"$ref": "#/$defs/digest"}, "cover_preview_path": {"$ref": "#/$defs/nonempty"}, "cover_preview_sha256": {"$ref": "#/$defs/digest"}, "adaptation_strategy": {"$ref": "#/$defs/nonempty"}, "preview_evidence_type": {"$ref": "#/$defs/nonempty"}, "visual_review_status": {"enum": ["pass", "fail", "not_reviewed"]}, "cover_delivery_status": {"enum": ["visual_pass", "visual_fail", "waiting_visual_review"]}, "video_title": {"$ref": "#/$defs/nonempty"}, "publish_description": {"$ref": "#/$defs/nonempty"}, "hashtags": {"$ref": "#/$defs/stringArray"}, "publish_readiness": {"enum": ["ready", "waiting_visual_review", "blocked"]}}}
  }
}
