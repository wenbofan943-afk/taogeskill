{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/r6/draft/v0.4",
  "title": "R6 source-tagged spoken draft v0.4",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "draft_id", "draft_revision", "draft_mode", "brief_ref", "content_source_id", "content_origin", "account_snapshot_ref", "body_text", "normalized_body_digest", "original_draft_ref", "original_normalized_body_digest", "structure_plan_ref", "review_ref", "revision_decision_ref", "authorization_refs", "draft_status", "next_skill"],
  "properties": {
    "schema_id": {"const": "taoge://schemas/r6/draft/v0.4"}, "schema_version": {"const": "0.4.0"}, "draft_id": {"$ref": "#/$defs/id"}, "draft_revision": {"type": "integer", "minimum": 1},
    "draft_mode": {"enum": ["materialize_user_baseline", "generate_from_structure", "revise_from_decision"]}, "brief_ref": {"$ref": "#/$defs/artifactRef"}, "content_source_id": {"$ref": "#/$defs/id"},
    "content_origin": {"enum": ["user_supplied_draft", "hotspot_selected_topic"]}, "account_snapshot_ref": {"$ref": "#/$defs/id"}, "body_text": {"type": "string", "minLength": 1}, "normalized_body_digest": {"$ref": "#/$defs/digest"},
    "original_draft_ref": {"$ref": "#/$defs/nullableArtifactRef"}, "original_normalized_body_digest": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/digest"}]}, "structure_plan_ref": {"$ref": "#/$defs/nullableArtifactRef"},
    "review_ref": {"$ref": "#/$defs/nullableArtifactRef"}, "revision_decision_ref": {"$ref": "#/$defs/nullableArtifactRef"}, "authorization_refs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
    "draft_status": {"enum": ["baseline_ready", "ready", "waiting_authorization", "blocked", "stale"]}, "next_skill": {"enum": ["content-beat-mapper", "spoken-script-review", "human_confirm"]}
  },
  "$defs": {"id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,127}$"}, "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}, "artifactRef": {"type": "object", "additionalProperties": false, "required": ["artifact_id", "revision", "sha256"], "properties": {"artifact_id": {"$ref": "#/$defs/id"}, "revision": {"type": "integer", "minimum": 1}, "sha256": {"$ref": "#/$defs/digest"}}}, "nullableArtifactRef": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/artifactRef"}]}}
}
