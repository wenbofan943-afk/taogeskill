{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schema/r6/direct-content-intake/v0.1",
  "title": "R6 Direct Content Intake",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "intake_id",
    "content_source_id",
    "session_id",
    "account",
    "content_origin",
    "topic_origin",
    "direct_intent",
    "revision_policy",
    "structural_rewrite_requested",
    "original_draft",
    "content_goal",
    "target_audiences",
    "claim_map",
    "direct_content_status",
    "human_gate",
    "next_skill",
    "lineage"
  ],
  "properties": {
    "schema_id": { "const": "taoge://r6/direct-content-intake/v0.1" },
    "schema_version": { "const": "0.1.0" },
    "intake_id": { "$ref": "#/$defs/id" },
    "content_source_id": { "$ref": "#/$defs/id" },
    "session_id": { "$ref": "#/$defs/id" },
    "account": {
      "type": "object",
      "additionalProperties": false,
      "required": ["account_id", "account_slug", "account_display_name", "identity_binding_id", "account_snapshot_id"],
      "properties": {
        "account_id": { "$ref": "#/$defs/id" },
        "account_slug": { "type": "string", "minLength": 1 },
        "account_display_name": { "type": "string", "minLength": 1 },
        "identity_binding_id": { "$ref": "#/$defs/id" },
        "account_snapshot_id": { "$ref": "#/$defs/id" }
      }
    },
    "content_origin": { "const": "user_supplied_draft" },
    "topic_origin": { "const": "direct_user_input" },
    "direct_intent": {
      "enum": ["direct_delivery", "direct_polish", "direct_evidence_enrichment", "direct_to_radar"]
    },
    "revision_policy": {
      "enum": ["preserve_voice", "polish_allowed", "rewrite_allowed"]
    },
    "structural_rewrite_requested": { "type": "boolean" },
    "original_draft": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "relative_path", "sha256", "character_count"],
      "properties": {
        "artifact_id": { "$ref": "#/$defs/id" },
        "relative_path": { "$ref": "#/$defs/relativePath" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "character_count": { "type": "integer", "minimum": 1 }
      }
    },
    "content_goal": { "type": "string", "minLength": 1 },
    "target_audiences": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "claim_map": {
      "type": "array",
      "items": { "$ref": "#/$defs/claim" }
    },
    "direct_content_status": {
      "enum": ["direct_content_ready", "needs_rewrite_confirmation", "blocked"]
    },
    "human_gate": { "type": "boolean" },
    "next_skill": {
      "enum": ["content-brief-compiler", "hotspot-topic-research", "human_confirm"]
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["producer_skill", "consumer_skill", "input_artifact_ids", "output_artifact_ids"],
      "properties": {
        "producer_skill": { "const": "direct-content-intake" },
        "consumer_skill": { "enum": ["content-brief-compiler", "hotspot-topic-research", "human_confirm"] },
        "input_artifact_ids": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/id" } },
        "output_artifact_ids": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/id" } }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "structural_rewrite_requested": { "const": true },
          "revision_policy": { "const": "preserve_voice" }
        },
        "required": ["structural_rewrite_requested", "revision_policy"]
      },
      "then": {
        "properties": {
          "direct_content_status": { "const": "needs_rewrite_confirmation" },
          "human_gate": { "const": true },
          "next_skill": { "const": "human_confirm" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "direct_intent": { "const": "direct_to_radar" },
          "direct_content_status": { "const": "direct_content_ready" }
        },
        "required": ["direct_intent", "direct_content_status"]
      },
      "then": {
        "properties": {
          "human_gate": { "const": false },
          "next_skill": { "const": "hotspot-topic-research" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "direct_intent": { "enum": ["direct_delivery", "direct_polish", "direct_evidence_enrichment"] },
          "direct_content_status": { "const": "direct_content_ready" }
        },
        "required": ["direct_intent", "direct_content_status"]
      },
      "then": {
        "properties": {
          "human_gate": { "const": false },
          "next_skill": { "const": "content-brief-compiler" }
        }
      }
    }
  ],
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,127}$" },
    "sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!.*\\.\\.)(?![A-Za-z]:)(?![\\\\/]).+"
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_id", "source_text", "claim_type", "claim_evidence_status"],
      "properties": {
        "claim_id": { "$ref": "#/$defs/id" },
        "source_text": { "type": "string", "minLength": 1 },
        "claim_type": {
          "enum": ["opinion", "experience", "factual_claim", "quote", "statistic", "prediction"]
        },
        "claim_evidence_status": {
          "enum": ["not_required", "supported", "refuted", "not_enough_info", "contested", "not_checked"]
        }
      }
    }
  }
}
