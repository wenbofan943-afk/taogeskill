{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/r6/script-visual-alignment-review/v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "alignment_review_id", "review_revision", "draft_ref", "structure_plan_ref", "beat_map_ref", "script_design_review_ref", "content_revision_decision_ref", "visual_need_analysis_ref", "coverage_ledger_ref", "checks", "alignment_status", "blocking_issue_ids", "warning_issue_ids", "created_at", "next_skill"],
  "properties": {
    "schema_id": {"const": "taoge://schemas/r6/script-visual-alignment-review/v0.1"},
    "schema_version": {"const": "0.1.0"},
    "alignment_review_id": {"$ref": "#/$defs/nonempty"},
    "review_revision": {"type": "integer", "minimum": 1},
    "draft_ref": {"$ref": "#/$defs/artifactRef"},
    "structure_plan_ref": {"$ref": "#/$defs/artifactRef"},
    "beat_map_ref": {"$ref": "#/$defs/artifactRef"},
    "script_design_review_ref": {"$ref": "#/$defs/artifactRef"},
    "content_revision_decision_ref": {"$ref": "#/$defs/artifactRef"},
    "visual_need_analysis_ref": {"$ref": "#/$defs/artifactRef"},
    "coverage_ledger_ref": {"$ref": "#/$defs/artifactRef"},
    "checks": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/check"}},
    "alignment_status": {"enum": ["pass", "pass_with_warnings", "needs_script_revision", "needs_visual_revision", "blocked", "stale"]},
    "blocking_issue_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonempty"}},
    "warning_issue_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonempty"}},
    "created_at": {"type": "string", "format": "date-time"},
    "next_skill": {"$ref": "#/$defs/nonempty"}
  },
  "$defs": {
    "nonempty": {"type": "string", "minLength": 1},
    "digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "artifactRef": {"type": "object", "additionalProperties": false, "required": ["artifact_id", "revision", "sha256"], "properties": {"artifact_id": {"$ref": "#/$defs/nonempty"}, "revision": {"type": "integer", "minimum": 1}, "sha256": {"$ref": "#/$defs/digest"}}},
    "check": {"type": "object", "additionalProperties": false, "required": ["check_id", "status", "finding", "beat_ids", "issue_id"], "properties": {"check_id": {"enum": ["beat_binding", "visual_job_fit", "evidence_binding", "presentation_fit", "redundancy", "cognitive_load", "asset_traceability", "readiness_binding"]}, "status": {"enum": ["pass", "warning", "fail"]}, "finding": {"$ref": "#/$defs/nonempty"}, "beat_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonempty"}}, "issue_id": {"type": ["string", "null"]}}}
  }
}
