{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/r6/source-capture-record/v0.1",
  "title": "R6 Source Capture Record v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id", "schema_version", "capture_id", "source_url", "fixture_mode",
    "screenshot_relative_path", "viewport", "attempt_number", "attempt_history",
    "capture_status", "started_at", "completed_at", "browser_path",
    "process_exit_code", "sha256", "file_size", "error_category"
  ],
  "properties": {
    "schema_id": { "const": "taoge://r6/source-capture-record/v0.1" },
    "schema_version": { "const": "0.1.0" },
    "capture_id": { "$ref": "#/$defs/id" },
    "source_url": { "type": "string", "minLength": 1 },
    "fixture_mode": { "type": "boolean" },
    "screenshot_relative_path": { "$ref": "#/$defs/relativePath" },
    "viewport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "minimum": 320 },
        "height": { "type": "integer", "minimum": 320 }
      }
    },
    "attempt_number": { "type": "integer", "minimum": 1 },
    "attempt_history": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["attempt_number", "started_at", "completed_at", "capture_status", "process_exit_code", "error_category"],
        "properties": {
          "attempt_number": { "type": "integer", "minimum": 1 },
          "started_at": { "type": ["string", "null"] },
          "completed_at": { "type": ["string", "null"] },
          "capture_status": { "enum": ["capture_failed", "interrupted_no_output"] },
          "process_exit_code": { "type": ["integer", "null"] },
          "error_category": { "type": ["string", "null"] }
        }
      }
    },
    "capture_status": { "enum": ["capture_started", "captured", "reconciled_existing_output", "capture_failed"] },
    "started_at": { "type": "string", "minLength": 1 },
    "completed_at": { "type": ["string", "null"] },
    "browser_path": { "type": "string", "minLength": 1 },
    "process_exit_code": { "type": ["integer", "null"] },
    "sha256": { "anyOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] },
    "file_size": { "type": ["integer", "null"], "minimum": 1 },
    "error_category": { "type": ["string", "null"] },
    "error_message_excerpt": { "type": "string", "maxLength": 240 }
  },
  "$defs": {
    "id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{2,127}$" },
    "sha256": { "type": "string", "pattern": "^[A-Fa-f0-9]{64}$" },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "(^[A-Za-z]:)|(^[/\\\\])|((^|[/\\\\])\\.\\.([/\\\\]|$))" }
    }
  }
}
