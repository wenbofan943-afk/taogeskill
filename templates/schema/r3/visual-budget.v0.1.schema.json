    "final_required_count": {"type":"integer","minimum":0}, "final_optional_count": {"type":"integer","minimum":0}, "selected_optional_count": {"type":"integer","minimum":0},
    "reduction_reason": {"type":["string","null"]}, "expansion_reason": {"type":["string","null"]},
    "cover_count_excluded": {"const":true},
    "required_visuals": {"type":"array","items":{"$ref":"#/$defs/visualTask"}},
