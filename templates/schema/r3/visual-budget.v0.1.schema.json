    "cover_generation_tasks": {"type":"array","items":{"$ref":"#/$defs/visualTask"}},
    "expected_pip_provider_call_count": {"type":"integer","minimum":0}, "expected_cover_provider_call_count": {"type":"integer","minimum":0}, "expected_provider_call_count": {"type":"integer","minimum":0}
  },
  "$defs": {"visualTask":{"type":"object","additionalProperties":false,"required":["image_task_id","beat_id","requirement_level","visual_role","retention_task","insert_after_text","insert_before_text","prompt_id","prompt_text","prompt_sha256","generation_intent","selected_for_generation"],"properties":{"image_task_id":{"type":"string","minLength":1},"beat_id":{"type":"string","minLength":1},"requirement_level":{"enum":["required","optional"]},"visual_role":{"type":"string","minLength":1},"retention_task":{"type":"string","minLength":1},"insert_after_text":{"type":"string","minLength":1},"insert_before_text":{"type":"string","minLength":1},"prompt_id":{"type":"string","minLength":1},"prompt_text":{"type":"string","minLength":1},"prompt_sha256":{"type":"string","pattern":"^sha256:[a-f0-9]{64}$"},"generation_intent":{"enum":["render_now","deliver_prompt_only","manual_required","omit"]},"selected_for_generation":{"type":"boolean"}}}}
}
