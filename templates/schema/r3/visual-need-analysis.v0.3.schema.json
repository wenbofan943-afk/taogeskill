{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/r3/visual-need-analysis/v0.3",
  "title": "R3 visual need analysis with typed presentation contracts v0.3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id", "schema_version", "visual_need_analysis_id", "static_visual_director_plan_id",
    "draft_id", "content_source_id", "content_origin", "account", "audience_profile_ref",
    "audience_prior_knowledge", "platform_viewing_context", "visual_count_policy", "generation_policy",
    "codex_provider", "cost_gate", "provider_call_limit", "accepted_task_dispatch_policy",
    "human_confirmation_required", "generation_dispatch_status", "next_skill", "cover_count_excluded",
    "semantic_beats", "candidates", "accepted_visual_tasks", "rejected_visual_candidate_ids",
    "derived_visual_count", "zero_visual_reason", "visual_need_analysis_status"
  ],
  "properties": {
    "schema_id": {"const": "taoge://schemas/r3/visual-need-analysis/v0.3"},
    "schema_version": {"const": "0.3"},
    "visual_need_analysis_id": {"$ref": "#/$defs/nonempty"},
    "static_visual_director_plan_id": {"$ref": "#/$defs/nonempty"},
    "draft_id": {"$ref": "#/$defs/nonempty"},
    "content_source_id": {"$ref": "#/$defs/nonempty"},
    "content_origin": {"enum": ["hotspot_selected_topic", "user_supplied_draft"]},
    "source_research_run_id": {"$ref": "#/$defs/nonempty"},
    "original_draft_artifact_id": {"$ref": "#/$defs/nonempty"},
    "original_draft_digest": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "account": {"$ref": "#/$defs/nonempty"},
    "audience_profile_ref": {"$ref": "#/$defs/nonempty"},
    "audience_prior_knowledge": {"enum": ["novice", "mixed", "expert", "unknown"]},
    "platform_viewing_context": {"enum": ["mobile_feed", "known_audience", "other"]},
    "visual_count_policy": {"const": "content_derived_unbounded"},
    "generation_policy": {"const": "generate_all_accepted"},
    "codex_provider": {"const": "codex_builtin_image2"},
    "cost_gate": {"const": "not_applicable"},
    "provider_call_limit": {"type": "null"},
    "accepted_task_dispatch_policy": {"const": "auto_continue_all_accepted_without_human_confirmation"},
    "human_confirmation_required": {"const": false},
    "generation_dispatch_status": {"enum": ["ready_for_prompt_compile", "not_ready"]},
    "next_skill": {"enum": ["image-prompt-compiler", "static-visual-director"]},
    "cover_count_excluded": {"const": true},
    "semantic_beats": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/beat"}},
    "candidates": {"type": "array", "items": {"$ref": "#/$defs/candidate"}},
    "accepted_visual_tasks": {"type": "array", "items": {"$ref": "#/$defs/task"}},
    "rejected_visual_candidate_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonempty"}},
    "derived_visual_count": {"type": "integer", "minimum": 0},
    "zero_visual_reason": {"type": ["string", "null"]},
    "visual_need_analysis_status": {"enum": ["pass", "needs_fix", "blocked"]}
  },
  "allOf": [
    {
      "if": {"properties": {"content_origin": {"const": "hotspot_selected_topic"}}, "required": ["content_origin"]},
      "then": {"required": ["source_research_run_id"]}
    },
    {
      "if": {"properties": {"content_origin": {"const": "user_supplied_draft"}}, "required": ["content_origin"]},
      "then": {"required": ["original_draft_artifact_id", "original_draft_digest"]}
    },
    {
      "if": {"properties": {"derived_visual_count": {"const": 0}}},
      "then": {"properties": {"zero_visual_reason": {"type": "string", "minLength": 1}}},
      "else": {"properties": {"zero_visual_reason": {"type": "null"}}}
    }
  ],
  "$defs": {
    "nonempty": {"type": "string", "minLength": 1},
    "ratio": {
      "type": "object", "additionalProperties": false, "required": ["ratio_width", "ratio_height", "orientation"],
      "properties": {"ratio_width": {"type": "integer", "minimum": 1}, "ratio_height": {"type": "integer", "minimum": 1}, "orientation": {"enum": ["portrait", "landscape", "square"]}}
    },
    "canvas": {
      "type": "object", "additionalProperties": false, "required": ["width_px", "height_px", "aspect_ratio"],
      "properties": {"width_px": {"type": "integer", "minimum": 1}, "height_px": {"type": "integer", "minimum": 1}, "aspect_ratio": {"$ref": "#/$defs/ratio"}}
    },
    "rect": {
      "type": "object", "additionalProperties": false, "required": ["x", "y", "width", "height"],
      "properties": {"x": {"type": "number", "minimum": 0, "maximum": 1}, "y": {"type": "number", "minimum": 0, "maximum": 1}, "width": {"type": "number", "exclusiveMinimum": 0, "maximum": 1}, "height": {"type": "number", "exclusiveMinimum": 0, "maximum": 1}}
    },
    "beat": {
      "type": "object", "additionalProperties": false, "required": ["beat_id", "script_range", "beat_purpose", "viewer_state_before", "viewer_state_after"],
      "properties": {"beat_id": {"$ref": "#/$defs/nonempty"}, "script_range": {"$ref": "#/$defs/nonempty"}, "beat_purpose": {"$ref": "#/$defs/nonempty"}, "viewer_state_before": {"$ref": "#/$defs/nonempty"}, "viewer_state_after": {"$ref": "#/$defs/nonempty"}}
    },
    "visualJob": {"enum": ["attention_reset", "hook_amplification", "concept_explanation", "evidence_support", "process_demonstration", "emotion_amplification", "memory_anchor"]},
    "candidate": {
      "type": "object", "additionalProperties": false,
      "required": [
        "visual_need_candidate_id", "beat_id", "covered_beat_ids", "trigger_text", "insert_after_text", "insert_before_text",
        "viewer_problem_without_visual", "attention_risk_without_visual", "comprehension_risk_without_visual",
        "primary_visual_job", "supporting_visual_jobs", "expected_viewer_change", "information_added",
        "why_image_is_better_than_talking_head", "attention_trigger_basis", "emotion_congruence_status",
        "evidence_requirement", "evidence_source_type", "evidence_source_id", "evidence_source_path",
        "redundancy_status", "cognitive_load_risk", "misleading_risk", "visual_need_decision", "decision_reason"
      ],
      "properties": {
        "visual_need_candidate_id": {"$ref": "#/$defs/nonempty"}, "beat_id": {"$ref": "#/$defs/nonempty"},
        "covered_beat_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/nonempty"}},
        "trigger_text": {"type": "string"}, "insert_after_text": {"type": "string"}, "insert_before_text": {"type": "string"},
        "viewer_problem_without_visual": {"type": "string"}, "attention_risk_without_visual": {"enum": ["low", "medium", "high"]},
        "comprehension_risk_without_visual": {"enum": ["low", "medium", "high"]}, "primary_visual_job": {"$ref": "#/$defs/visualJob"},
        "supporting_visual_jobs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/visualJob"}},
        "expected_viewer_change": {"type": "string"}, "information_added": {"type": "string"}, "why_image_is_better_than_talking_head": {"type": "string"},
        "attention_trigger_basis": {"enum": ["specific_content_risk", "elapsed_time_only", "not_applicable"]},
        "emotion_congruence_status": {"enum": ["aligned", "not_applicable", "misaligned"]},
        "evidence_requirement": {"enum": ["source_bound", "generated_context_only", "not_applicable"]},
        "evidence_source_type": {"type": ["string", "null"]}, "evidence_source_id": {"type": ["string", "null"]}, "evidence_source_path": {"type": ["string", "null"]},
        "redundancy_status": {"enum": ["unique", "duplicates_narration", "duplicates_other_visual"]},
        "cognitive_load_risk": {"enum": ["low", "medium", "high"]}, "misleading_risk": {"enum": ["low", "medium", "high"]},
        "visual_need_decision": {"enum": ["generate", "reject"]}, "decision_reason": {"$ref": "#/$defs/nonempty"}
      }
    },
    "task": {
      "type": "object", "additionalProperties": false,
      "required": [
        "image_task_id", "visual_insert_task_id", "visual_need_candidate_id", "beat_id", "primary_visual_job",
        "generation_intent", "provider_route", "image_production_path", "presentation_mode", "platform_surface_profile_id",
        "video_canvas", "visual_asset_canvas", "placement_slot", "speaker_region", "caption_safe_area",
        "platform_ui_safe_areas", "protected_regions", "aspect_ratio_verification_status"
      ],
      "properties": {
        "image_task_id": {"$ref": "#/$defs/nonempty"}, "visual_insert_task_id": {"$ref": "#/$defs/nonempty"},
        "visual_need_candidate_id": {"$ref": "#/$defs/nonempty"}, "beat_id": {"$ref": "#/$defs/nonempty"},
        "primary_visual_job": {"$ref": "#/$defs/visualJob"}, "generation_intent": {"const": "render_now"},
        "provider_route": {"enum": ["codex_builtin_image2", "news_evidence_pip"]},
        "image_production_path": {"enum": ["codex_image2_render", "source_capture"]},
        "presentation_mode": {"enum": ["full_frame_replace", "speaker_plus_visual", "split_screen", "floating_card", "source_evidence_card", "background_plate"]},
        "platform_surface_profile_id": {"$ref": "#/$defs/nonempty"},
        "video_canvas": {"$ref": "#/$defs/canvas"}, "visual_asset_canvas": {"$ref": "#/$defs/canvas"},
        "placement_slot": {"$ref": "#/$defs/rect"}, "speaker_region": {"oneOf": [{"$ref": "#/$defs/rect"}, {"type": "null"}]},
        "caption_safe_area": {"$ref": "#/$defs/rect"}, "platform_ui_safe_areas": {"type": "array", "items": {"$ref": "#/$defs/rect"}},
        "protected_regions": {"type": "array", "items": {"$ref": "#/$defs/rect"}},
        "aspect_ratio_verification_status": {"enum": ["planned", "pass", "fail"]}
      }
    }
  }
}
