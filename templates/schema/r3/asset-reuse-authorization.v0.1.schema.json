{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/r3/asset-reuse-authorization/v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "authorization_id", "authorization_mode", "session_id", "visual_task_id", "account_snapshot_id", "authorized_asset_refs", "created_by", "created_at", "scope"],
  "properties": {
    "schema_id": {"const": "taoge://schemas/r3/asset-reuse-authorization/v0.1"},
    "schema_version": {"const": "0.1.0"},
    "authorization_id": {"type": "string", "minLength": 1},
    "authorization_mode": {"enum": ["user_supplied_for_current_run", "human_selected_for_current_run", "account_preapproved_asset"]},
    "session_id": {"type": "string", "minLength": 1},
    "visual_task_id": {"type": "string", "minLength": 1},
    "account_snapshot_id": {"type": "string", "minLength": 1},
    "authorized_asset_refs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/assetRef"}},
    "created_by": {"enum": ["human", "account_profile_owner"]},
    "created_at": {"type": "string", "format": "date-time"},
    "scope": {"const": "exact_session_task_asset_hash"}
  },
  "$defs": {
    "assetRef": {"type": "object", "additionalProperties": false, "required": ["artifact_id", "sha256"], "properties": {"artifact_id": {"type": "string", "minLength": 1}, "sha256": {"type": "string", "pattern": "^(sha256:)?[a-f0-9]{64}$"}}}
  }
}
