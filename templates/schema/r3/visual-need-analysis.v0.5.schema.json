{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/r3/visual-need-analysis/v0.5",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_id", "schema_version", "visual_need_analysis_id", "analysis_revision", "session_id", "account_snapshot_id", "draft_id", "content_source_id", "content_origin", "visual_count_policy", "provider_call_limit", "human_confirmation_required", "test_profile", "semantic_beats", "candidates", "accepted_visual_tasks", "derived_visual_count", "zero_visual_reason", "visual_need_analysis_status", "generation_dispatch_status", "next_skill"],
  "properties": {
    "schema_id": {"const": "taoge://schemas/r3/visual-need-analysis/v0.5"},
    "schema_version": {"const": "0.5.0"},
    "visual_need_analysis_id": {"type": "string", "minLength": 1},
    "analysis_revision": {"type": "integer", "minimum": 1},
    "session_id": {"type": "string", "minLength": 1},
    "account_snapshot_id": {"type": "string", "minLength": 1},
    "draft_id": {"type": "string", "minLength": 1},
    "content_source_id": {"type": "string", "minLength": 1},
    "content_origin": {"enum": ["hotspot_selected_topic", "user_supplied_draft"]},
    "source_research_run_id": {"type": "string"},
    "original_draft_artifact_id": {"type": "string"},
    "original_draft_digest": {"type": "string"},
    "visual_count_policy": {"const": "content_derived_unbounded"},
    "provider_call_limit": {"type": "null"},
    "human_confirmation_required": {"const": false},
    "test_profile": {"enum": ["production", "no_provider", "reuse_only"]},
    "semantic_beats": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "candidates": {"type": "array", "items": {"type": "object"}},
    "accepted_visual_tasks": {"type": "array", "items": {"$ref": "visual-source-routing.v0.1.schema.json"}},
    "rejected_visual_candidate_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "derived_visual_count": {"type": "integer", "minimum": 0},
    "zero_visual_reason": {"type": ["string", "null"]},
    "visual_need_analysis_status": {"enum": ["pass", "needs_fix", "blocked"]},
    "generation_dispatch_status": {"enum": ["ready_for_routed_production", "not_ready"]},
    "next_skill": {"enum": ["talking-head-image-pip", "static-visual-director"]}
  }
}
