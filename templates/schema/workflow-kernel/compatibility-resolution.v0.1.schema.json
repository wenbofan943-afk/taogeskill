{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://workflow-kernel/compatibility-resolution/v0.1",
  "title": "Read-only legacy workflow compatibility resolution",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "architecture_change_id",
    "blueprint_id",
    "blueprint_version",
    "route_id",
    "runtime_generation",
    "runtime_entry_ref",
    "plan_sha256",
    "compatibility_catalog_sha256",
    "resolution_status",
    "read_only",
    "migration_allowed"
  ],
  "properties": {
    "schema_id": {"const": "taoge://workflow-kernel/compatibility-resolution/v0.1"},
    "schema_version": {"const": "0.1"},
    "architecture_change_id": {"const": "ARCH-20260718-002"},
    "blueprint_id": {"type": "string", "minLength": 1},
    "blueprint_version": {"type": "string", "pattern": "^0\\.[1-6]$"},
    "route_id": {"enum": ["direct", "hotspot"]},
    "runtime_generation": {"const": "legacy_r7"},
    "runtime_entry_ref": {"const": "tools/invoke-r7-semantic-workflow.ps1"},
    "plan_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "compatibility_catalog_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "resolution_status": {"const": "legacy_resume_only"},
    "read_only": {"const": true},
    "migration_allowed": {"const": false}
  }
}
