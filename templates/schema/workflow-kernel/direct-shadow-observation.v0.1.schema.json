{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://workflow-kernel/direct-shadow-observation/v0.1",
  "title": "Direct shadow normalized observation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "observation_kind",
    "real_legacy_runtime_executed",
    "input_sha256",
    "artifact_projection_sha256",
    "event_projection_sha256",
    "stop_reason",
    "final_html_sha256"
  ],
  "properties": {
    "schema_id": {
      "const": "taoge://workflow-kernel/direct-shadow-observation/v0.1"
    },
    "schema_version": {
      "const": "0.1"
    },
    "observation_kind": {
      "enum": ["frozen_legacy_contract_fixture", "real_legacy_runtime_observation", "kernel_v1_shadow_observation"]
    },
    "real_legacy_runtime_executed": {
      "type": "boolean"
    },
    "input_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "artifact_projection_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "event_projection_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "stop_reason": {
      "const": "waiting_human"
    },
    "final_html_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "shadow_session_id": { "type": "string" },
    "source_session_id": { "type": "string" },
    "artifact_count": { "type": "integer", "minimum": 0 },
    "event_count": { "type": "integer", "minimum": 0 },
    "runtime_generation": { "type": "string" },
    "current_runtime_generation": { "type": "string" },
    "runtime_switch_enabled": { "type": "boolean" },
    "current_write_performed": { "type": "boolean" }
  }
}
