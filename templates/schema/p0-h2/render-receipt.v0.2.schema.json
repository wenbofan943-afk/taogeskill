{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/p0/render-receipt/v0.2",
  "title": "Taoge P0 deterministic render receipt v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "receipt_id", "render_input_sha256", "renderer_version", "template_sha256", "included_card_ids", "included_asset_ids", "warning_codes", "output_html_sha256"],
  "properties": {
    "schema_id": {"const": "taoge://schemas/p0/render-receipt/v0.2"},
    "schema_version": {"const": "0.2"},
    "receipt_id": {"type": "string", "minLength": 1},
    "render_input_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "renderer_version": {"const": "final-delivery-renderer-v0.2"},
    "template_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "included_card_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
    "included_asset_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "warning_codes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "output_html_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
  }
}
