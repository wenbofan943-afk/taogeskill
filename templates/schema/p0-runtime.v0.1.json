{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Taoge P0 lightweight runtime",
  "type": "object",
  "additionalProperties": false,
  "required": ["plan_id", "session_id", "workflow_version", "steps"],
  "properties": {
    "plan_id": {"type": "string", "minLength": 1},
    "session_id": {"type": "string", "minLength": 1},
    "workflow_version": {"const": "p0-runtime-v0.1"},
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/step"}
    }
  },
  "$defs": {
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step_id", "step_kind", "failure_route"],
      "properties": {
        "step_id": {"type": "string", "minLength": 1},
        "step_kind": {"enum": ["deterministic_tool", "agent_required", "human_gate", "external_side_effect"]},
        "operation": {"type": "string"},
        "requires_step_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "requires_artifact_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "produces_artifact_type": {"type": "string"},
        "success_state": {"const": "succeeded"},
        "failure_route": {"type": "string", "minLength": 1}
      },
      "allOf": [
        {
          "if": {"properties": {"step_kind": {"const": "deterministic_tool"}}},
          "then": {"required": ["operation"]}
        }
      ]
    }
  }
}
