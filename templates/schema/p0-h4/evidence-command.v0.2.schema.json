{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://commands/p0/evidence-command/v0.2",
  "title": "P0-H4 evidence and reconciliation command",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "schema_version", "command", "session_id"],
  "properties": {
    "schema_id": {"const": "taoge://commands/p0/evidence-command/v0.2"},
    "schema_version": {"const": "0.2"},
    "command": {"enum": ["create_session_plan", "record_agent_result", "record_human_choice", "record_external_result", "reconcile_orphan_artifact"]},
    "session_id": {"type": "string", "minLength": 1},
    "plan_id": {"type": "string", "minLength": 1},
    "confirmed_single_content": {"type": "boolean"},
    "steps": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "step_id": {"type": "string", "minLength": 1},
    "artifact_id": {"type": "string", "minLength": 1},
    "artifact_type": {"type": "string", "minLength": 1},
    "relative_path": {"type": "string", "pattern": "^(?![A-Za-z]:|/|\\\\)(?!.*\\.\\.).+$"},
    "input_artifact_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "quality_status": {"enum": ["not_run", "pass", "pass_with_warnings", "fail", "human_review_required"]},
    "delivery_eligibility": {"enum": ["blocked", "trace_only", "preview_only", "ready_for_delivery", "ready_for_upload"]},
    "check_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "decision_id": {"type": "string", "minLength": 1},
    "decision_code": {"enum": ["topic_selected", "final_delivery_approved", "revision_requested", "archived", "cancel_requested"]},
    "selected_artifact_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "authorization_status": {"enum": ["authorized", "not_authorized"]},
    "invocation_status": {"enum": ["not_invoked", "succeeded", "failed", "outcome_unknown"]},
    "request_id": {"type": "string"},
    "failure_category": {"enum": ["contract", "input", "transient_environment", "tool", "external_provider", "authorization", "quality", "unknown"]},
    "cost_may_have_occurred": {"type": "boolean"},
    "expected_sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "input_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "tool_version": {"type": "string", "minLength": 1},
    "action": {"enum": ["adopt", "quarantine"]},
    "idempotency_key": {"type": "string", "minLength": 1},
    "expected_last_sequence_no": {"type": "integer", "minimum": 0},
    "safe_summary": {"type": "string", "minLength": 1, "maxLength": 240},
    "supersedes_event_id": {"type": "string", "minLength": 1}
  },
  "allOf": [
    {"if": {"properties": {"command": {"const": "create_session_plan"}}}, "then": {"required": ["plan_id", "confirmed_single_content", "steps", "idempotency_key", "expected_last_sequence_no", "safe_summary"]}},
    {"if": {"properties": {"command": {"const": "record_agent_result"}}}, "then": {"required": ["step_id", "artifact_id", "artifact_type", "relative_path", "input_artifact_ids", "quality_status", "delivery_eligibility", "check_ids", "idempotency_key", "expected_last_sequence_no", "safe_summary"]}},
    {"if": {"properties": {"command": {"const": "record_human_choice"}}}, "then": {"required": ["step_id", "decision_id", "decision_code", "selected_artifact_ids", "idempotency_key", "expected_last_sequence_no", "safe_summary"]}},
    {"if": {"properties": {"command": {"const": "record_external_result"}}}, "then": {"required": ["step_id", "authorization_status", "invocation_status", "idempotency_key", "expected_last_sequence_no", "safe_summary"]}},
    {"if": {"properties": {"command": {"const": "reconcile_orphan_artifact"}}}, "then": {"required": ["step_id", "artifact_id", "artifact_type", "relative_path", "input_artifact_ids", "expected_sha256", "input_digest", "tool_version", "action", "idempotency_key", "expected_last_sequence_no", "safe_summary"]}}
  ]
}
