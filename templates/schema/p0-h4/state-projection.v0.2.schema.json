{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/p0/state-projection/v0.2",
  "title": "P0-H4 rebuildable session state projection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id", "schema_version", "projection_version", "session_id", "plan_id",
    "projected_through_sequence_no", "source_event_digest", "source_last_recorded_at",
    "current_state", "completed_step_ids", "waiting_step_id", "next_step_id",
    "non_repeatable_step_ids", "step_states"
  ],
  "properties": {
    "schema_id": {"const": "taoge://schemas/p0/state-projection/v0.2"},
    "schema_version": {"const": "0.2"},
    "projection_version": {"const": "p0-state-projection-v0.2"},
    "session_id": {"type": "string", "minLength": 1},
    "plan_id": {"type": "string", "minLength": 1},
    "projected_through_sequence_no": {"type": "integer", "minimum": 0},
    "source_event_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "source_last_recorded_at": {"type": ["string", "null"]},
    "current_state": {"enum": ["ready", "completed", "running", "waiting_agent", "waiting_human", "waiting_external", "not_invoked", "failed", "blocked", "outcome_unknown", "attempt_interrupted", "cancel_requested", "cancel_pending_external"]},
    "completed_step_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "waiting_step_id": {"type": ["string", "null"]},
    "next_step_id": {"type": ["string", "null"]},
    "non_repeatable_step_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "step_states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step_id", "step_kind", "state", "latest_event_id"],
        "properties": {
          "step_id": {"type": "string"},
          "step_kind": {"enum": ["deterministic_tool", "agent_required", "human_gate", "external_side_effect"]},
          "state": {"type": "string"},
          "latest_event_id": {"type": ["string", "null"]}
        }
      }
    }
  }
}
