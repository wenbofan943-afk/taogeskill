{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://schemas/r5/column-visual-templates/v0.2",
  "title": "R5 account-bound column visual templates",
  "type": "object",
  "required": ["schema_id", "schema_version", "account_slug", "account_identity_id", "account_technical_slug", "templates"],
  "properties": {
    "schema_id": {"const": "taoge://schemas/r5/column-visual-templates/v0.2"},
    "schema_version": {"const": "0.2"},
    "account_slug": {"type": "string", "minLength": 1},
    "account_identity_id": {"type": "string", "minLength": 1},
    "account_technical_slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["column_template_id", "column_name", "applies_when", "viewer_job", "preferred_visual_roles", "cover_hierarchy_override", "visual_rules", "prohibited_patterns"],
        "properties": {
          "column_template_id": {"type": "string", "minLength": 1},
          "column_name": {"type": "string", "minLength": 1},
          "applies_when": {"type": "string", "minLength": 1},
          "viewer_job": {"type": "string", "minLength": 1},
          "preferred_visual_roles": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "cover_hierarchy_override": {"type": "array", "items": {"type": "string", "minLength": 1}},
          "visual_rules": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "prohibited_patterns": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
