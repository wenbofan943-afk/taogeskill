{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "taoge://account/radar-policy/v0.1",
  "type": "object",
  "required": ["schema_id", "schema_version", "policy_id", "account_slug", "policy_status", "audience_priority", "used_car_priority_mode", "new_car_spillover_threshold", "new_car_spillover_proof_types", "topic_priority_rules", "topic_exclusions", "manual_watchlist_policy", "lexicon_feedback_policy"],
  "properties": {
    "schema_id": {"const": "taoge://account/radar-policy/v0.1"},
    "schema_version": {"const": 0.1},
    "policy_id": {"type": "string", "minLength": 1},
    "account_slug": {"type": "string", "minLength": 1},
    "policy_status": {"enum": ["policy_draft", "policy_active", "policy_needs_review", "policy_blocked"]},
    "audience_priority": {"type": "array", "minItems": 1, "items": {"enum": ["buyer", "seller", "dealer"]}, "uniqueItems": true},
    "used_car_priority_mode": {"const": "direct_first"},
    "new_car_spillover_threshold": {"const": 3},
    "new_car_spillover_proof_types": {"type": "array", "minItems": 1, "items": {"enum": ["residual_value", "trade_in", "inventory_cashflow", "used_nev_circulation", "policy_transmission"]}},
    "topic_priority_rules": {"type": "array", "minItems": 1},
    "topic_exclusions": {"type": "array"},
    "manual_watchlist_policy": {"const": "reason_and_review_required"},
    "lexicon_feedback_policy": {"const": "exploratory_selection_feedback"}
  },
  "additionalProperties": false
}
