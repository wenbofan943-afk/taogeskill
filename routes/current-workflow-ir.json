    {
      "stage_id": "intake",
      "order": 1,
      "responsibility": "materialize account, source content, radar policy, and route entry facts",
      "allowed_stop_reasons": ["input_contract_incomplete", "waiting_human", "blocked"]
    },
    {
      "stage_id": "research_topic",
      "order": 2,
      "responsibility": "research, candidate projection, topic decision, and selected-source commit",
      "allowed_stop_reasons": ["waiting_external", "waiting_human", "topic_gate", "blocked"]
    },
    {
      "stage_id": "script_design",
      "order": 3,
      "responsibility": "brief, structure, draft, beat map, script review, and revision decision",
      "allowed_stop_reasons": ["waiting_human", "waiting_authorization", "blocked"]
    },
    {
      "stage_id": "visual_plan",
      "order": 4,
      "responsibility": "visual need, intent, exclusive source route, and generated prompt brief",
      "allowed_stop_reasons": ["waiting_capability", "waiting_authorization", "blocked"]
    },
    {
      "stage_id": "asset_production",
      "order": 5,
      "responsibility": "external or deterministic production, asset review, and final asset selection",
      "allowed_stop_reasons": ["waiting_external", "waiting_capability", "revision_required", "blocked"]
    },
    {
      "stage_id": "delivery_compile",
      "order": 6,
      "responsibility": "alignment, platform package, cover, freshness, HTML, viewport, and business acceptance",
      "allowed_stop_reasons": ["waiting_external", "revision_required", "delivery_blocked", "blocked"]
    },
    {
      "stage_id": "final_decision",
      "order": 7,
      "responsibility": "typed final human decision and deterministic decision application",
      "allowed_stop_reasons": ["waiting_human", "revision_required", "completed", "archived", "blocked"]
    }
  ],
  "transition_policy": {
    "mode": "ordered_single_route",
    "advance_authority": "deterministic_coordinator_only",
    "normal_transition": "next_stage",
    "wait_transition": "same_stage",
    "failure_transition": "same_stage_or_declared_recovery",
    "terminal_stage": "final_decision",
    "external_side_effect_protocol": "request_attempt_outcome_output_reference_acceptance",
    "resume_policy": "reconcile_persisted_outcome_before_retry",
    "time_source": "caller_materialized_only"
